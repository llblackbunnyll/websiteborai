<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="วิทยาลัยการอาชีพบ่อไร่ - สถาบันการศึกษาวิชาชีพชั้นนำของจังหวัดตราด" />
  <title><%= title %></title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- Floating orb canvas — fixed behind all sections -->
  <div class="section-canvas-wrap">
    <canvas id="section-canvas"></canvas>
  </div>

  <%- include('partials/navbar') %>

  <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
  <%- include('partials/hero') %>

  <!-- ════════════════════ SUB-BANNER + QUICK LINKS ════════════════ -->
  <%- include('partials/sub-banner') %>

  <!-- ══════════════════════════ NEWS ════════════════════════════ -->
  <%- include('partials/news', { newsItems: newsItems }) %>

  <!-- ═══════════════════════════ DIRECTOR ════════════════════════ -->
  <!-- Director section removed temporarily -->

  <!-- ═══════════════════════════ ABOUT ══════════════════════════ -->
  <%- include('partials/about') %>

  <!-- ════════════════════════ DEPARTMENTS ═══════════════════════ -->
  <%# include('partials/departments') %>

  <!-- ═══════════════════════════ FAQ ═════════════════════════════ -->
  <%- include('partials/faq-section') %>

  <!-- ═══════════════════════════ CONTACT ═══════════════════════════ -->
  <%- include('partials/contact') %>

  <%- include('partials/footer') %>

  <!-- Department Modal -->
  <%# 
  <div id="dept-modal-overlay" class="modal-overlay">
    <div class="modal-box glass">
      <div class="modal-header">
        <div style="display:flex;align-items:center;gap:1rem;">
          <div class="modal-icon"></div>
          <div>
            <h3 class="modal-dept-name" style="font-size:1.4rem;font-weight:700;color:var(--color-text-primary);"></h3>
            <p class="modal-dept-sub" style="font-size:0.85rem;color:var(--color-text-secondary);margin-top:0.2rem;"></p>
          </div>
        </div>
        <button id="dept-modal-close" class="modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="study-plan-grid"></div>
        <div class="modal-note">* รายวิชาอาจมีการเปลี่ยนแปลงตามโครงสร้างหลักสูตรของสถานศึกษา</div>
      </div>
    </div>
  </div>
  %>

  <script src="/js/webgl-bg.js"></script>
  <script src="/js/particles.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>