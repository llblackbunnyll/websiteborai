<!-- CONTACT SECTION -->
<section class="contact-section" id="contact">
  <div class="contact-glow"></div>

  <div class="container" style="position:relative;z-index:1;">
    <div class="contact-card glass reveal">
      <div style="text-align:center;">
        <h2 class="section-title" style="margin-bottom:0.5rem;">Get in <span class="text-gradient">Touch</span></h2>
        <p style="color:var(--color-text-secondary);">มีคำถาม? เราพร้อมช่วยเหลือคุณเสมอ</p>
      </div>

      <div class="contact-grid">
        <!-- Info -->
        <div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.57 3.4 2 2 0 0 1 3.55 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.61a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <div class="contact-info-label">โทรศัพท์</div>
              <div class="contact-info-value">+66 39 511 111</div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="contact-info-label">อีเมล</div>
              <div class="contact-info-value">info@borai.ac.th</div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="contact-info-label">ที่อยู่</div>
              <div class="contact-info-value">อำเภอบ่อไร่ จังหวัดตราด ประเทศไทย</div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <form class="contact-form" onsubmit="return false;">
          <input type="text" class="form-input" placeholder="ชื่อของคุณ" />
          <input type="email" class="form-input" placeholder="อีเมลของคุณ" />
          <textarea class="form-input" placeholder="ข้อความ" rows="4"></textarea>
          <button type="button" class="btn-submit">
            ส่งข้อความ
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
    </div>

    <!-- Map -->
    <div class="map-wrapper glass reveal">
      <iframe
        title="แผนที่วิทยาลัยการอาชีพบ่อไร่"
        src="https://maps.google.com/maps?width=100%25&height=600&hl=th&q=วิทยาลัยการอาชีพบ่อไร่+(Borai%20Industrial%20and%20Community%20Education%20College)&t=&z=16&ie=UTF8&iwloc=B&output=embed"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
