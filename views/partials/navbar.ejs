  <!-- Universal Navbar Script (Handles Toggle & Accordion) -->
  <script>
    (function() {
      const hamburger = document.getElementById('nav-hamburger');
      const mobileMenu = document.getElementById('nav-mobile-menu');
      if (!hamburger || !mobileMenu) return;

      // Toggle Mobile Drawer
      hamburger.addEventListener('click', (e) => {
        e.stopPropagation();
        mobileMenu.classList.toggle('open');
        const isOpen = mobileMenu.classList.contains('open');
        hamburger.innerHTML = isOpen 
          ? `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
          : `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
      });

      // Handle Mobile Accordions
      const dropdowns = mobileMenu.querySelectorAll('.nav-mobile-dropdown');
      dropdowns.forEach(dd => {
        const toggle = dd.querySelector('.nav-mobile-dropdown-toggle');
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isActive = dd.classList.contains('active');
          // Close others
          dropdowns.forEach(other => other.classList.remove('active'));
          // Toggle current
          if (!isActive) dd.classList.add('active');
        });
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!mobileMenu.contains(e.target) && !hamburger.contains(e.target)) {
          mobileMenu.classList.remove('open');
          hamburger.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        }
      });
    })();
  </script>
