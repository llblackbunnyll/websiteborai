<!-- DEPARTMENTS SECTION -->
<section class="departments-section" id="departments">
  <div class="container">
    <h2 class="section-title reveal">
      แผนกวิชา<span class="text-gradient">ที่เปิดสอน</span>
    </h2>

    <div class="dept-grid" style="margin-top:2.5rem;">

      <!-- IT -->
      <div class="dept-card glass reveal-scale" data-dept="it" style="transition-delay:0s;">
        <div class="dept-icon" style="background: linear-gradient(135deg, #8b5cf640, #8b5cf6);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3 class="dept-name">คอมพิวเตอร์ธุรกิจ/ไอที</h3>
        <span class="dept-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          แผนการเรียน
        </span>
      </div>

      <!-- Accounting -->
      <div class="dept-card glass reveal-scale" data-dept="acc" style="transition-delay:0.1s;">
        <div class="dept-icon" style="background: linear-gradient(135deg, #f59e0b40, #f59e0b);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3 class="dept-name">การบัญชี</h3>
        <span class="dept-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
