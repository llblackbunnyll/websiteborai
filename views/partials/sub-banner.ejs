<!-- ═══════════════════ SUB-BANNER + QUICK LINKS ═══════════════════ -->
<section class="sub-banner-section" id="sub-banner">

  <!-- ─── Quick-Link Menu Row (บน) ────────────────────────────────── -->
  <div class="sub-menu-bar">
    <div class="container">
      <nav class="sub-menu-nav" aria-label="เมนูลัด">

        <a href="/about" class="sub-menu-item reveal" style="transition-delay:0s;">
          <span class="sub-menu-icon">
            <!-- Book / About Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
          </span>
          <span class="sub-menu-label">ข้อมูลวิทยาลัย</span>
        </a>

        <a href="/curriculum" class="sub-menu-item reveal" style="transition-delay:0.07s;">
          <span class="sub-menu-icon">
            <!-- Academic Cap Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
              <path d="M6 12v5c3 3 9 3 12 0v-5" />
            </svg>
          </span>
          <span class="sub-menu-label">หลักสูตร / สาขาวิชา</span>
        </a>

        <a href="/personnel" class="sub-menu-item reveal" style="transition-delay:0.14s;">
          <span class="sub-menu-icon">
            <!-- Users Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </span>
          <span class="sub-menu-label">บุคลากร</span>
        </a>

        <a href="#" class="sub-menu-item reveal" style="transition-delay:0.21s;">
          <span class="sub-menu-icon">
            <!-- Calendar Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
          </span>
          <span class="sub-menu-label">ปฏิทินการศึกษา</span>
          <span class="sub-menu-chip">เร็วๆนี้</span>
        </a>

        <a href="/documents" class="sub-menu-item reveal" style="transition-delay:0.28s;">
          <span class="sub-menu-icon">
            <!-- Download Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </span>
          <span class="sub-menu-label">เอกสาร / ดาวน์โหลด</span>
        </a>

        <a href="/#contact" class="sub-menu-item reveal" style="transition-delay:0.35s;">
          <span class="sub-menu-icon">
            <!-- Map Pin Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </span>
          <span class="sub-menu-label">ติดต่อ / แผนที่</span>
        </a>

      </nav>
    </div>
  </div>



  <!-- ─── Floating Banner Slideshow (ล่าง) ────────────────────────── -->
  <div class="sub-banner-card reveal" id="sub-banner-card">
    <div class="sub-banner-overlay"></div>

    <!-- Slides Container -->
    <div class="sub-banner-slides" id="sub-banner-slides">
      <% const sbImages = typeof subBannerImages !== 'undefined' && subBannerImages.length > 0
           ? subBannerImages : ['/subbannerImage.png']; %>
      <% sbImages.forEach((img, idx) => { %>
        <img
          src="<%= img %>"
          alt="วิทยาลัยการอาชีพบ่อไร่ — แบนเนอร์ <%= idx + 1 %>"
          class="sub-banner-slide<%= idx === 0 ? ' active' : '' %>"
          loading="<%= idx === 0 ? 'eager' : 'lazy' %>"
        />
      <% }) %>
    </div>

    <!-- Dots Indicator (only show when >1 image) -->
    <% if (sbImages.length > 1) { %>
    <div class="sub-banner-dots" id="sub-banner-dots">
      <% sbImages.forEach((_, idx) => { %>
        <button class="sub-banner-dot<%= idx === 0 ? ' active' : '' %>" data-idx="<%= idx %>" aria-label="ภาพที่ <%= idx + 1 %>"></button>
      <% }) %>
    </div>
    <% } %>

    <!-- Badge -->
    <div class="sub-banner-badge">
      <span class="sub-banner-badge-dot"></span>
      วิทยาลัยการอาชีพบ่อไร่ · BICEC
    </div>
  </div>

</section>

<script>
(function() {
  const card   = document.getElementById('sub-banner-card');
  const slides = document.querySelectorAll('.sub-banner-slide');
  const dots   = document.querySelectorAll('.sub-banner-dot');
  if (!card || slides.length <= 1) return;

  let current  = 0;
  let timer    = null;
  const DELAY  = 4500;

  function goTo(n) {
    slides[current].classList.remove('active');
    if (dots[current]) dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    if (dots[current]) dots[current].classList.add('active');
  }

  function start() {
    timer = setInterval(() => goTo(current + 1), DELAY);
  }

  function stop() {
    clearInterval(timer);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      stop();
      goTo(parseInt(dot.dataset.idx));
      start();
    });
  });

  card.addEventListener('mouseenter', stop);
  card.addEventListener('mouseleave', start);
  start();
})();
</script>
