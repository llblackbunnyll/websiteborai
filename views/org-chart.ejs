<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ผังการบริหารวิทยาลัยการอาชีพบ่อไร่ — โครงสร้างการบริหารทั้ง 4 ฝ่าย" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --oc-purple: #7042f8;
      --oc-blue: #0ea5e9;
      --oc-teal: #10b981;
      --oc-amber: #f59e0b;
      --oc-bg: #f4f6fb;
      --oc-border: #e2e8f0;
      --oc-text: #0f172a;
      --oc-muted: #64748b
    }

    body {
      font-family: 'Sarabun', sans-serif;
      background: var(--oc-bg);
      color: var(--oc-text);
      min-height: 100vh
    }

    /* HERO */
    .oc-hero {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      color: #fff;
      padding: 120px 24px 80px;
      text-align: center;
      position: relative;
      overflow: hidden
    }

    .oc-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(112, 66, 248, .35) 0%, transparent 70%);
      pointer-events: none
    }

    .oc-hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .55);
      background: rgba(255, 255, 255, .07);
      border: 1px solid rgba(255, 255, 255, .12);
      border-radius: 100px;
      padding: 6px 16px;
      margin-bottom: 20px
    }

    .oc-hero h1 {
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -1px;
      margin-bottom: 14px
    }

    .oc-hero h1 span {
      background: linear-gradient(135deg, #a78bfa, #38bdf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text
    }

    .oc-hero-sub {
      font-size: 1rem;
      color: rgba(255, 255, 255, .6);
      max-width: 560px;
      margin: 0 auto 28px;
      line-height: 1.7
    }

    .oc-breadcrumb {
      font-size: .84rem;
      color: rgba(255, 255, 255, .45)
    }

    .oc-breadcrumb a {
      color: #a78bfa;
      text-decoration: none
    }

    .oc-breadcrumb span {
      margin: 0 8px
    }

    .oc-particle {
      position: absolute;
      border-radius: 50%;
      background: rgba(167, 139, 250, .18);
      pointer-events: none;
      animation: floatPart 8s ease-in-out infinite
    }

    @keyframes floatPart {

      0%,
      100% {
        transform: translateY(0) scale(1)
      }

      50% {
        transform: translateY(-24px) scale(1.05)
      }
    }

    /* STATS */
    .oc-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      max-width: 900px;
      margin: -36px auto 56px;
      padding: 0 24px;
      position: relative;
      z-index: 20
    }

    .oc-stat-card {
      background: #fff;
      border: 1px solid var(--oc-border);
      border-radius: 18px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 8px 24px rgba(0, 0, 0, .06);
      position: relative;
      overflow: hidden
    }

    .oc-stat-card::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(135deg, #7042f8, #0ea5e9)
    }

    .oc-stat-val {
      font-size: 1.8rem;
      font-weight: 900;
      background: linear-gradient(135deg, #7042f8, #0ea5e9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.1
    }

    .oc-stat-lbl {
      font-size: .75rem;
      color: var(--oc-muted);
      font-weight: 500;
      margin-top: 4px
    }

    /* CHART */
    .oc-wrap {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px 80px
    }

    .oc-top {
      display: flex;
      justify-content: center
    }

    .director-card {
      background: #fff;
      border: 1px solid #e8e4f8;
      border-radius: 24px;
      padding: 32px 48px 28px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(112, 66, 248, .10);
      min-width: 280px;
      transition: transform .25s, box-shadow .25s;
    }

    .director-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(112, 66, 248, .16)
    }

    /* Director Photo */
    .director-photo-wrap {
      position: relative;
      width: 96px;
      height: 96px;
      margin: 0 auto 16px;
    }

    .director-photo {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid #ede9fe;
      display: block;
    }

    .director-label {
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #7042f8;
      margin-bottom: 10px;
      display: block;
    }

    .director-name {
      font-size: 1.3rem;
      font-weight: 800;
      color: #1e1b4b;
      letter-spacing: -.2px
    }

    .director-sub {
      font-size: .76rem;
      color: #94a3b8;
      margin-top: 4px;
      font-weight: 500
    }

    .director-divider {
      width: 36px;
      height: 2px;
      background: linear-gradient(to right, #7042f8, #0ea5e9);
      margin: 12px auto;
      border-radius: 2px;
    }


    /* CONNECTORS */
    .oc-connector-v {
      width: 3px;
      height: 48px;
      background: linear-gradient(to bottom, #7042f8, #c4b5fd);
      margin: 0 auto;
      border-radius: 2px
    }

    .oc-connector-h {
      position: relative;
      height: 3px
    }

    .oc-connector-h::before {
      content: '';
      position: absolute;
      top: 0;
      left: calc(12.5% + 1px);
      right: calc(12.5% + 1px);
      height: 3px;
      background: linear-gradient(to right, #7042f8, #c4b5fd, #7042f8);
      border-radius: 2px
    }

    /* DEPT COLUMNS */
    .oc-depts {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px
    }

    .oc-dept-col {
      display: flex;
      flex-direction: column;
      align-items: center
    }

    .oc-dept-col::before {
      content: '';
      width: 3px;
      height: 36px;
      background: linear-gradient(to bottom, #c4b5fd, var(--dept-color));
      border-radius: 2px;
      flex-shrink: 0
    }

    /* DEPT HEADER (non-clickable label) */
    .dept-header {
      background: var(--dept-color);
      color: #fff;
      border-radius: 18px;
      padding: 18px 14px 14px;
      text-align: center;
      width: 100%;
      box-shadow: 0 10px 30px rgba(0, 0, 0, .15)
    }

    .dept-icon-box {
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, .2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 10px
    }

    .dept-badge {
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      opacity: .8;
      margin-bottom: 4px
    }

    .dept-title {
      font-size: .95rem;
      font-weight: 800;
      line-height: 1.3
    }

    .dept-count {
      margin-top: 8px;
      display: inline-block;
      background: rgba(255, 255, 255, .2);
      border-radius: 20px;
      padding: 2px 12px;
      font-size: .72rem;
      font-weight: 700
    }

    .dept-v-line {
      width: 3px;
      height: 28px;
      background: var(--dept-color);
      opacity: .5;
      border-radius: 2px;
      flex-shrink: 0
    }

    /* JOBS BOX */
    .jobs-box {
      width: 100%;
      background: #fff;
      border-radius: 16px;
      border: 1px solid var(--oc-border);
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0, 0, 0, .05)
    }

    .jobs-box-header {
      padding: 10px 14px 8px;
      background: #f8fafc;
      border-bottom: 1px solid var(--oc-border);
      font-size: .7rem;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--oc-muted)
    }

    /* CLICKABLE JOB ITEM */
    .job-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 14px;
      border-bottom: 1px solid #f1f5f9;
      cursor: pointer;
      transition: background .2s, transform .15s;
      position: relative;
      user-select: none
    }

    .job-item:last-child {
      border-bottom: none
    }

    .job-item:hover {
      background: linear-gradient(to right, rgba(var(--dept-rgb), .06), transparent);
      transform: translateX(3px)
    }

    .job-item:hover .job-arrow {
      opacity: 1;
      transform: translateX(0)
    }

    .job-item.active {
      background: linear-gradient(to right, rgba(var(--dept-rgb), .1), rgba(var(--dept-rgb), .03))
    }

    .job-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--dept-color);
      flex-shrink: 0;
      margin-top: 6px;
      transition: transform .2s
    }

    .job-item:hover .job-dot {
      transform: scale(1.4)
    }

    .job-text {
      font-size: .82rem;
      font-weight: 600;
      color: #334155;
      line-height: 1.45;
      flex: 1
    }

    .job-arrow {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      opacity: 0;
      transform: translateX(-6px);
      transition: all .2s;
      color: var(--dept-color);
      margin-top: 4px
    }

    /* EXECUTIVE IMAGES IN HEADERS */
    .exec-img-ctx {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid rgba(255, 255, 255, .34);
      background: #fff;
      margin-bottom: 12px;
      box-shadow: 0 4px 12px rgba(0, 0, 0, .15)
    }

    .dept-exec-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      text-align: left;
      padding: 0 4px
    }

    .dept-exec-img {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(255, 255, 255, .4);
      background: #fff;
      flex-shrink: 0
    }

    .dept-exec-info {
      flex: 1;
      min-width: 0
    }

    .dept-exec-name {
      font-size: .85rem;
      font-weight: 800;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis
    }

    .dept-exec-pos {
      font-size: .65rem;
      opacity: .85;
      font-weight: 600
    }

    /* LEGEND */
    .oc-legend {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
      margin: 36px 0 0
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 18px;
      background: #fff;
      border: 1px solid var(--oc-border);
      border-radius: 100px;
      font-size: .82rem;
      font-weight: 600;
      color: #334155;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .04)
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%
    }

    /* REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .7s ease, transform .7s ease
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0)
    }

    /* DRAWER */
    .oc-drawer-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 12, 41, .45);
      backdrop-filter: blur(4px);
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity .35s ease
    }

    .oc-drawer-overlay.open {
      opacity: 1;
      pointer-events: auto
    }

    .oc-drawer {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(500px, 100vw);
      background: #fff;
      z-index: 1001;
      transform: translateX(100%);
      transition: transform .4s cubic-bezier(.25, .46, .45, .94);
      display: flex;
      flex-direction: column;
      box-shadow: -20px 0 60px rgba(0, 0, 0, .2)
    }

    .oc-drawer.open {
      transform: translateX(0)
    }

    .drawer-head {
      padding: 24px 24px 18px;
      border-bottom: 1px solid #f1f5f9;
      flex-shrink: 0;
      position: relative
    }

    .drawer-dept-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .68rem;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
      border-radius: 6px;
      padding: 3px 10px;
      margin-bottom: 10px
    }

    .drawer-job-name {
      font-size: 1.1rem;
      font-weight: 900;
      color: #0f172a;
      line-height: 1.3;
      margin-bottom: 4px
    }

    .drawer-meta {
      font-size: .8rem;
      color: #64748b
    }

    .drawer-count-pill {
      display: inline-block;
      background: #f1f5f9;
      border-radius: 20px;
      padding: 2px 10px;
      font-size: .72rem;
      font-weight: 700;
      color: #334155;
      margin-top: 8px
    }

    .drawer-close {
      position: absolute;
      top: 20px;
      right: 20px;
      width: 36px;
      height: 36px;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
      background: #f8fafc;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all .2s;
      color: #64748b
    }

    .drawer-close:hover {
      background: #7042f8;
      color: #fff;
      border-color: #7042f8
    }

    .drawer-body {
      flex: 1;
      overflow-y: auto;
      padding: 20px 24px 32px
    }

    /* person cards */
    .person-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 14px;
      background: #fff;
      border: 1px solid #f1f5f9;
      margin-bottom: 10px;
      transition: all .2s;
      box-shadow: 0 2px 6px rgba(0, 0, 0, .04)
    }

    .person-card:hover {
      border-color: rgba(112, 66, 248, .2);
      box-shadow: 0 6px 20px rgba(112, 66, 248, .1);
      transform: translateX(3px)
    }

    .person-card.is-head {
      border-left: 3px solid var(--dc, #7042f8)
    }

    .person-photo {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid #f1f5f9;
      background: #f8fafc
    }

    .person-card.is-head .person-photo {
      width: 64px;
      height: 64px;
      border-color: rgba(112, 66, 248, .25)
    }

    .person-info {
      flex: 1;
      min-width: 0
    }

    .person-badge {
      display: inline-block;
      font-size: .6rem;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
      border-radius: 4px;
      padding: 2px 7px;
      margin-bottom: 3px
    }

    .person-name {
      font-size: .9rem;
      font-weight: 800;
      color: #0f172a;
      line-height: 1.25
    }

    .person-acad {
      font-size: .73rem;
      color: #7042f8;
      font-weight: 600;
      margin-top: 2px
    }

    .person-pos {
      font-size: .75rem;
      color: #64748b;
      margin-top: 1px
    }

    .person-dept {
      font-size: .67rem;
      color: #94a3b8;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 4px;
      padding: 1px 7px;
      margin-top: 4px;
      display: inline-block
    }

    .section-sep {
      font-size: .67rem;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #94a3b8;
      margin: 16px 0 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid #f1f5f9;
      display: flex;
      align-items: center;
      gap: 6px
    }

    .section-sep:first-child {
      margin-top: 0
    }

    .drawer-empty {
      text-align: center;
      padding: 48px 20px;
      color: #94a3b8
    }

    .drawer-empty p {
      font-size: .9rem;
      margin-top: 10px
    }

    .drawer-footer {
      padding: 16px 24px;
      border-top: 1px solid #f1f5f9;
      flex-shrink: 0;
      background: #fafafa
    }

    .drawer-footer a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: .85rem;
      font-weight: 700;
      color: #7042f8;
      text-decoration: none;
      padding: 10px;
      border-radius: 12px;
      border: 1px solid rgba(112, 66, 248, .15);
      background: #fff;
      transition: all .25s
    }

    .drawer-footer a:hover {
      background: #7042f8;
      color: #fff
    }

    @media(max-width:1100px) {
      .oc-depts {
        grid-template-columns: repeat(2, 1fr)
      }

      .oc-connector-h::before {
        left: calc(25% + 1px);
        right: calc(25% + 1px)
      }
    }

    @media(max-width:640px) {
      .oc-depts {
        grid-template-columns: 1fr
      }

      .oc-stats {
        grid-template-columns: repeat(2, 1fr)
      }

      .oc-drawer {
        width: 100vw
      }
    }

    /* ORDERS SECTION */
    .oc-orders-section {
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid rgba(112, 66, 248, .1);
    }

    .oc-orders-head {
      text-align: center;
      margin-bottom: 40px;
    }

    .oc-orders-eyebrow {
      display: inline-block;
      font-size: .65rem;
      font-weight: 800;
      color: #7042f8;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 8px;
    }

    .oc-orders-title {
      font-size: 1.8rem;
      font-weight: 800;
      color: #1e1b4b;
    }

    .orders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    .order-card {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all .3s ease;
      text-decoration: none;
      box-shadow: 0 4px 12px rgba(0, 0, 0, .03);
    }

    .order-card:hover {
      border-color: #7042f8;
      transform: translateY(-3px);
      box-shadow: 0 12px 24px rgba(112, 66, 248, .08);
    }

    .order-icon-box {
      width: 48px;
      height: 48px;
      background: rgba(112, 66, 248, 0.06);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #7042f8;
      flex-shrink: 0;
    }

    .order-info {
      flex: 1;
      min-width: 0;
    }

    .order-name {
      font-size: .92rem;
      font-weight: 700;
      color: #334155;
      line-height: 1.4;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .order-meta {
      font-size: .75rem;
      color: #94a3b8;
      margin-top: 4px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .order-dl-btn {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #f1f5f9;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #64748b;
      transition: all .2s;
    }

    .order-card:hover .order-dl-btn {
      background: #7042f8;
      color: #fff;
    }
  </style>
</head>

<body>
  <%- include('partials/navbar') %>

    <% const personnel=typeof allPersonnel !=='undefined' ? allPersonnel : []; const
      personnelJSON=JSON.stringify(personnel.map(p=> {
      let duties = [];
      if (p.duties) {
      try { duties = Array.isArray(p.duties) ? p.duties : JSON.parse(p.duties); } catch(e) {}
      }
      return {
      id: p.id,
      prefix: p.prefix || '',
      firstName: p.firstName || '',
      lastName: p.lastName || '',
      position: p.position || '',
      academicStanding: p.academicStanding || '',
      department: p.department || '',
      imageUrl: p.imageUrl || '',
      isDirector: p.isDirector || false,
      duties: duties
      };
      }));

      // Find Specific Executives for the chart headers
      const findExec = (kw, deptKw) => personnel.find(p => {
      const dts = Array.isArray(p.duties) ? p.duties : (p.duties ? JSON.parse(p.duties) : []);
      const hay = (dts.join(' ') + ' ' + (p.position||'')).toLowerCase();
      // ค้นหาว่าในหน้าที่/ตำแหน่ง มีทั้งคำว่า "รองผู้อำนวยการ" และชื่อฝ่ายที่ต้องการหรือไม่
      return hay.includes(kw.toLowerCase()) && (!deptKw || hay.includes(deptKw.toLowerCase()));
      });

      const directorObj = personnel.find(p => p.isDirector) || findExec('ผู้อำนวยการ');
      const deputy1 = findExec('รองผู้อำนวยการ', 'บริหารทรัพยากร');
      const deputy2 = findExec('รองผู้อำนวยการ', 'แผนงาน');
      const deputy3 = findExec('รองผู้อำนวยการ', 'กิจการ');
      const deputy4 = findExec('รองผู้อำนวยการ', 'วิชาการ');

      function getExecName(p, fallback = 'ยังไม่ได้กำหนด') {
      if (!p) return fallback;
      return (p.prefix || '') + p.firstName + ' ' + p.lastName;
      }
      function getExecImg(p) {
      return (p && p.imageUrl) ? p.imageUrl : '/images/default-person.svg';
      }
