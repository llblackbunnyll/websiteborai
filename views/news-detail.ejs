<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .news-detail-page { padding: 120px 0 80px; min-height: 80vh; }
    .news-detail-container { max-width: 900px; margin: 0 auto; }
    
    .news-detail-header { margin-bottom: 2.5rem; text-align: left; }
    .news-detail-title { font-size: 2.5rem; font-weight: 800; line-height: 1.25; margin-bottom: 1rem; color: #1e293b; }
    
    .news-meta-wrap { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; color: var(--color-text-secondary); font-size: 0.95rem; }
    .meta-item { display: flex; align-items: center; gap: 0.5rem; }
    
    .main-image-wrap { width: 100%; border-radius: 1.5rem; overflow: hidden; margin-bottom: 3rem; background: var(--color-bg-secondary); border: 1px solid rgba(0,0,0,0.05); }
    .main-image-wrap img { width: 100%; height: auto; display: block; }
    
    .news-content-text { font-size: 1.15rem; line-height: 1.8; color: #334155; margin-bottom: 4rem; white-space: pre-line; }
    
    .gallery-section { margin-top: 4rem; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 3rem; }
    .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
    .gallery-item { border-radius: 0.75rem; overflow: hidden; cursor: pointer; border: 1px solid rgba(0,0,0,0.05); }
    .gallery-item img { width: 100%; height: 180px; object-fit: cover; transition: scale 0.3s ease; }
    .gallery-item:hover img { scale: 1.05; }
    
    .back-nav { margin-bottom: 2rem; }
    .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-accent-primary); font-weight: 600; text-decoration: none; transition: transform 0.2s; }
    .back-link:hover { transform: translateX(-5px); }

    @media (max-width: 768px) {
      .news-detail-title { font-size: 1.8rem; }
      .meta-wrap { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    }
  </style>
</head>
<body>

  <!-- Floating orb canvas — fixed behind all sections -->
  <div class="section-canvas-wrap">
    <canvas id="section-canvas"></canvas>
  </div>

  <%- include('partials/navbar') %>

  <main class="news-detail-page">
    <div class="container news-detail-container">
      
      <div class="back-nav reveal" style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <a href="/#news" class="btn-outline" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; border-radius: 100px; padding: 0.6rem 1.5rem; font-weight: 600;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          กลับหน้าหลัก
        </a>
        <a href="/news" class="btn-outline" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; border-radius: 100px; padding: 0.6rem 1.5rem; font-weight: 600;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          ดูข่าวทั้งหมด
        </a>
      </div>

      <article class="reveal">
        <div class="news-detail-header">
          <div style="margin-bottom: 1rem;">
             <span class="news-badge" style="position: static; font-size: 0.85rem;"><%= news.category %></span>
             <% if (news.departmentTag === 'พัสดุ') { %>
              <span class="news-badge" style="position: static; font-size: 0.85rem; background: #ef4444; margin-left: 0.5rem;">งานพัสดุ</span>
             <% } %>
          </div>
          <h1 class="news-detail-title"><%= news.title %></h1>
          
          <div class="news-meta-wrap">
            <div class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <%= news.date %>
            </div>
            <div class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              วิทยาลัยการอาชีพบ่อไร่
            </div>
          </div>
        </div>

        <div class="main-image-wrap glass">
          <img src="<%= news.image %>" alt="<%= news.title %>" onerror="this.src='https://placehold.co/1200x800/f1f5f9/94a3b8?text=BICEC+News'" />
        </div>

        <div class="news-content-text">
          <%= news.content %>
        </div>

        <% if (news.images && Array.isArray(news.images) && news.images.length > 0) { %>
        <section class="gallery-section reveal">
          <h2 style="font-size: 1.5rem; font-weight: 700; color: #1e293b;">อัลบั้มรูปภาพ</h2>
          <div class="gallery-grid">
            <% news.images.forEach(function(imgUrl, i) { %>
            <div class="gallery-item glass" onclick="window.open('<%= imgUrl %>', '_blank')">
              <img src="<%= imgUrl %>" alt="ภาพประกอบข่าว <%= i + 1 %>" loading="lazy" />
            </div>
            <% }); %>
          </div>
        </section>
        <% } %>
      </article>

      <div style="margin-top: 5rem; text-align: center; display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;" class="reveal">
        <a href="/news" class="btn btn-secondary">ดูข่าวทั้งหมด</a>
        <a href="/#news" class="btn btn-primary">กลับหน้าหลัก</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/webgl-bg.js"></script>
  <script src="/js/particles.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
