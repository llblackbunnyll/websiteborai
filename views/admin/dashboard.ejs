<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .duty-unified-container {
      position: relative;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(112, 66, 248, 0.2);
      border-radius: 12px;
      padding: 0.6rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      transition: all 0.3s ease;
      min-height: 54px;
      cursor: text;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .duty-unified-container:focus-within {
      border-color: var(--color-accent-primary);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 32px rgba(112, 66, 248, 0.1);
    }
    .duty-tag {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.8rem;
      background: linear-gradient(135deg, rgba(112, 66, 248, 0.1), rgba(66, 133, 244, 0.1));
      border: 1px solid rgba(112, 66, 248, 0.2);
      border-radius: 8px;
      color: var(--color-text-primary);
      font-size: 0.85rem;
      font-weight: 500;
      animation: chipScale 0.2s ease-out;
    }
    @keyframes chipScale {
      from { transform: scale(0.8); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .duty-remove-btn {
      cursor: pointer;
      font-weight: bold;
      color: var(--color-error);
      font-size: 1.1rem;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      opacity: 0.6;
    }
    .duty-remove-btn:hover { opacity: 1; }
    .duty-inner-input {
      flex: 1;
      min-width: 150px;
      background: transparent !important;
      border: none !important;
      outline: none !important;
      color: #333 !important;
      font-weight: 500 !important;
      padding: 0.5rem !important;
      font-size: 1rem !important;
      box-shadow: none !important;
      caret-color: var(--color-accent-primary);
    }
    .duty-inner-input::placeholder {
      color: rgba(0, 0, 0, 0.35);
    }
    .duty-suggestion-list {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(15, 15, 25, 0.98);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid var(--color-accent-primary);
      border-radius: 0.8rem;
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
      max-height: 220px;
      overflow-y: auto;
      display: none;
      padding: 0.4rem;
    }
    .duty-suggestion-item {
      padding: 0.8rem 1.2rem;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.9);
      border-radius: 0.6rem;
      transition: all 0.2s ease;
      font-size: 0.9rem;
    }
    .duty-suggestion-item:hover {
      background: linear-gradient(90deg, rgba(112, 66, 248, 0.3), rgba(66, 133, 244, 0.1));
      color: white;
      padding-left: 1.5rem;
    }
    .duty-suggestion-list::-webkit-scrollbar { width: 5px; }
    .duty-suggestion-list::-webkit-scrollbar-thumb {
      background: var(--color-accent-primary);
      border-radius: 10px;
    }
  </style>
</head>
<body class="admin-body">

<div class="admin-layout">
  <!-- Mobile Header (Visible only on small screens) -->
  <div class="mobile-header">
    <button id="sidebar-toggle" class="sidebar-toggle-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="mobile-logo">
      <img src="/my-logo.webp" alt="Logo" />
      <span>Admin Panel</span>
    </div>
  </div>

  <!-- Sidebar Overlay -->
  <div class="admin-overlay" id="admin-overlay"></div>
  
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <img src="/my-logo.webp" alt="BICEC Logo" />
      <div>
        <h2>Admin Panel</h2>
        <p>วิทยาลัยการอาชีพบ่อไร่</p>
      </div>
    </div>
    
    <nav class="admin-nav">
      <button class="nav-btn active" data-target="pr-panel">
        <span>📰</span> ข่าวสาร/ประชาสัมพันธ์
      </button>
      <button class="nav-btn" data-target="personnel-panel">
        <span>👥</span> ข้อมูลบุคลากร
      </button>
      <button class="nav-btn" data-target="docs-panel">
        <span>📄</span> เอกสารและประกวดราคา
      </button>
      <button class="nav-btn" data-target="others-panel">
        <span>📦</span> ระบบอื่นๆ
      </button>
    </nav>
    
    <div class="admin-sidebar-footer">
      <button class="btn-outline w-full mb-1" onclick="window.location.href='/'">
        หน้าเว็บไซต์
      </button>
      <button id="logout-btn" class="btn-outline btn-danger w-full">
        ออกจากระบบ
      </button>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main class="admin-main-content">
    
    <!-- ========================= PR PANEL ========================= -->
    <section id="pr-panel" class="admin-panel active">
      <div class="panel-header">
        <div>
          <h1>ข่าวสาร และ ประชาสัมพันธ์</h1>
          <p>จัดการประกาศ กิจกรรม และข่าวสารหน้าเว็บไซต์</p>
        </div>
        <button id="pr-add-btn" class="btn-accent">+ เพิ่มข่าวสาร</button>
      </div>

      <!-- PR Form -->
      <div id="pr-form-container" class="admin-card hide">
        <h3 id="pr-form-title" class="mb-2">เพิ่มรายการใหม่</h3>
        <form id="pr-form" enctype="multipart/form-data">
          <input type="hidden" id="pr-id" />
          <div class="form-grid">
            <div class="form-group form-full">
              <label for="pr-title">หัวข้อ</label>
              <input id="pr-title" name="title" type="text" class="form-control" required />
            </div>

            <div class="form-group">
              <label for="pr-category">หมวดหมู่</label>
              <select id="pr-category" name="category" class="form-control" required>
                <option value="ข่าวสาร">ข่าวสาร (News)</option>
                <option value="ประกาศ">ประกาศ (Announcement)</option>
                <option value="กิจกรรม">กิจกรรม (Activity)</option>
              </select>
            </div>

            <div class="form-group hide" id="pr-department-group">
              <label for="pr-departmentTag">สังกัด (พิเศษ)</label>
              <select id="pr-departmentTag" name="departmentTag" class="form-control">
                <option value="">-- ไม่ระบุ --</option>
                <option value="งานพัสดุ">งานพัสดุ</option>
              </select>
            </div>

            <div class="form-group">
              <label for="pr-date">วันที่ (ข้อความ)</label>
              <input id="pr-date" name="date" type="text" class="form-control" placeholder="เช่น 15 มี.ค. 2569" required />
            </div>

            <div class="form-group form-full">
              <label for="pr-images">รูปภาพ (เลือกได้หลายรูป)</label>
              <!-- multiple attribute added -->
              <input id="pr-images" name="images" type="file" accept="image/*" multiple class="form-control file-input" />
              <small class="text-muted">รูปแรกจะถูกใช้เป็นภาพหน้าปก</small>
            </div>

            <div class="form-group form-full">
              <label for="pr-content">เนื้อหา</label>
              <textarea id="pr-content" name="content" class="form-control" rows="4"></textarea>
            </div>
          </div>
          <div class="form-actions mt-2">
            <button type="button" id="pr-cancel-btn" class="btn-outline">ยกเลิก</button>
            <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
          </div>
        </form>
      </div>

      <!-- PR Table -->
      <div class="admin-card">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th>หัวข้อ</th>
                <th>ประเภท</th>
                <th>วันที่</th>
                <th style="text-align:right;">จัดการ</th>
              </tr>
            </thead>
            <tbody id="pr-tbody">
              <tr><td colspan="4" style="text-align:center;">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========================= PERSONNEL PANEL ========================= -->
    <section id="personnel-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>ข้อมูลบุคลากร</h1>
          <p>จัดการรายชื่อ ตำแหน่ง และข้อมูลบุคลากรในวิทยาลัย</p>
        </div>
        <div style="display:flex; gap:0.5rem;">
          <button id="personnel-import-btn" class="btn-outline">📥 นำเข้า Excel</button>
          <button id="personnel-add-btn" class="btn-accent">+ เพิ่มบุคลากร</button>
        </div>
      </div>

      <!-- Personnel Import -->
      <div id="personnel-import-container" class="admin-card hide" style="border: 2px dashed var(--color-accent-primary); background: rgba(112,66,248,0.03);">
        <h3 class="mb-1">นำเข้าข้อมูลจาก Excel (.xlsx)</h3>
        <p class="text-muted mb-2" style="font-size:0.9rem;">
          ระบบจะตรวจจับคอลลั่มโดยอัตโนมัติจากหัวตาราง (เช่น ชื่อ-สกุล, ตำแหน่ง, วิทยฐานะ, เลขที่ตำแหน่ง, สังกัด)
        </p>
        <form id="personnel-import-form">
          <div style="display:flex; gap:1rem; align-items:center;">
            <input type="file" id="excel-file" name="excel" accept=".xlsx, .xls" class="form-control file-input" required style="max-width:300px;" />
            <button type="submit" class="btn-accent">เริ่มนำเข้า</button>
            <button type="button" id="personnel-import-cancel-btn" class="btn-outline">ยกเลิก</button>
          </div>
        </form>
      </div>

      <!-- Personnel Form -->
      <div id="personnel-form-container" class="admin-card hide">
        <h3 id="personnel-form-title" class="mb-2">เพิ่มบุคลากรใหม่</h3>
        <form id="personnel-form" enctype="multipart/form-data">
          <input type="hidden" id="personnel-id" />
          <div class="form-grid">
            <div class="form-group">
              <label for="personnel-prefix">คำนำหน้า</label>
              <input id="personnel-prefix" name="prefix" type="text" class="form-control" placeholder="นาย/นาง/นางสาว" />
            </div>
            <div class="form-group">
              <label for="personnel-firstName">ชื่อ *</label>
              <input id="personnel-firstName" name="firstName" type="text" class="form-control" required />
            </div>
            <div class="form-group">
              <label for="personnel-lastName">นามสกุล *</label>
              <input id="personnel-lastName" name="lastName" type="text" class="form-control" required />
            </div>
            <div class="form-group">
              <label for="personnel-position">ตำแหน่งหลัก</label>
              <input id="personnel-position" name="position" type="text" class="form-control" placeholder="ครู, เจ้าหน้าที่..." />
            </div>
            <div class="form-group">
              <label for="personnel-academicStanding">วิทยฐานะ</label>
              <input id="personnel-academicStanding" name="academicStanding" type="text" class="form-control" placeholder="ชำนาญการ, เชี่ยวชาญ..." />
            </div>
            <div class="form-group">
              <label for="personnel-positionNumber">เลขที่ตำแหน่ง</label>
              <input id="personnel-positionNumber" name="positionNumber" type="text" class="form-control" />
            </div>
            <div class="form-group">
              <label for="personnel-department">สังกัด/แผนก</label>
              <input id="personnel-department" name="department" type="text" class="form-control" placeholder="แผนกวิชา..., งาน..." />
            </div>
            <div class="form-group">
              <label for="personnel-phone">เบอร์ติดต่อ</label>
              <input id="personnel-phone" name="phone" type="text" class="form-control" />
            </div>
            <div class="form-group form-full">
              <label>หน้าที่รับผิดชอบ</label>
              <div id="duty-unified-field" class="duty-unified-container">
                <div id="duty-tag-container" style="display:contents;"></div>
                <input type="text" id="new-duty-input" class="duty-inner-input" placeholder="เพิ่ม..." autocomplete="off" />
                <div id="duty-suggestions" class="duty-suggestion-list"></div>
              </div>
            </div>
            <div class="form-group">
              <label for="personnel-order">ลำดับการแสดงผล</label>
              <input id="personnel-order" name="order" type="number" class="form-control" value="0" />
            </div>
            <div class="form-group form-full">
              <label for="personnel-image">รูปประจำตัว</label>
              <input id="personnel-image" name="image" type="file" accept="image/*" class="form-control file-input" />
            </div>
          </div>
          <div class="form-actions mt-2">
            <button type="button" id="personnel-cancel-btn" class="btn-outline">ยกเลิก</button>
            <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
          </div>
        </form>
      </div>

      <!-- Personnel Table -->
      <div class="admin-card mt-2">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width: 60px; text-align:center;">ลำดับ</th>
                <th>ชื่อ-นามสกุล</th>
                <th>ตำแหน่ง/วิทยฐานะ</th>
                <th>สังกัด/เลขที่ตำแหน่ง</th>
                <th style="text-align:right;">จัดการ</th>
                <th style="width: 70px; text-align:center;">
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.25rem; padding: 0.2rem 0;">
                  <input type="checkbox" id="personnel-select-all" title="เลือกทั้งหมด" />
                  <button id="personnel-bulk-delete-btn" class="icon-btn danger hide" title="ลบที่เลือก" style="width: 28px; height: 28px; padding: 0; min-height: unset; border-radius: 6px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    <span id="bulk-delete-count" style="font-size: 0.65rem; font-weight: 700; margin-left: 1px; line-height: 1;"></span>
                  </button>
                </div>
              </th>
              </tr>
            </thead>
            <tbody id="personnel-tbody">
              <tr><td colspan="6" style="text-align:center;">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========================= DOCUMENTS PANEL ========================= -->
    <section id="docs-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>เอกสาร และ ข่าวประกวดราคา</h1>
          <p>จัดการไฟล์เอกสารเผยแพร่ และข่าวจัดซื้อจัดจ้าง (PDF)</p>
        </div>
        <button id="doc-add-btn" class="btn-accent">+ เพิ่มเอกสาร</button>
      </div>

      <!-- Doc Form -->
      <div id="doc-form-container" class="admin-card hide">
        <form id="doc-form" enctype="multipart/form-data">
          <div class="form-grid">
            <div class="form-group form-full">
              <label for="doc-title">หัวข้อเอกสาร</label>
              <input id="doc-title" name="title" type="text" class="form-control" required />
            </div>

            <div class="form-group">
              <label for="doc-type">ประเภท</label>
              <select id="doc-type" name="type" class="form-control" required>
                <option value="bidding">ข่าวประกวดราคา (Bidding)</option>
                <option value="general">เอกสารเผยแพร่ (Document)</option>
              </select>
            </div>

            <div class="form-group">
              <label for="doc-date">วันที่ปะหน้า</label>
              <input id="doc-date" name="date" type="text" class="form-control" placeholder="เช่น 15 มี.ค. 2569" required />
            </div>

            <div class="form-group form-full">
              <label for="doc-file">ไฟล์เอกสาร (PDF เท่านั้น)</label>
              <input id="doc-file" name="file" type="file" accept=".pdf" class="form-control file-input" required />
            </div>
          </div>
          <div class="form-actions mt-2">
            <button type="button" id="doc-cancel-btn" class="btn-outline">ยกเลิก</button>
            <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
          </div>
        </form>
      </div>

      <!-- Docs Table -->
      <div class="admin-card mt-2">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th>ชื่อเอกสาร</th>
                <th>ประเภท</th>
                <th>วันที่ประกาศ</th>
                <th style="text-align:right;">จัดการ</th>
              </tr>
            </thead>
            <tbody id="docs-tbody">
              <tr><td colspan="4" style="text-align:center;">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========================= OTHERS PANEL ========================= -->
    <section id="others-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>ระบบอื่นๆ</h1>
          <p>ส่วนขยายสำหรับอนาคต</p>
        </div>
      </div>
      <div class="admin-card" style="text-align:center; padding: 4rem 2rem;">
        <h2 style="color:var(--color-text-secondary); margin-bottom: 1rem;">หน้านี้ยังไม่เปิดใช้งาน</h2>
        <p class="text-muted">กำลังเตรียมระบบสำหรับฟีเจอร์ใหม่ๆ ในการอัปเดตครั้งถัดไป</p>
      </div>
    </section>

  </main>
</div>

<script src="/js/admin.js"></script>
</body>
</html>
