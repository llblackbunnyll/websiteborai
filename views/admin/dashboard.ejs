          <div class="stat-mini-label" style="color: var(--color-accent-primary);">สถานะการแสดงหน้าเว็บ (Public)</div>
          <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.85rem;">
            <div id="budget-status-text" style="font-size: 0.95rem; font-weight: 800; color: #10b981;">🟢 เปิดใช้งานปกติ</div>
            <label class="admin-switch">
              <input type="checkbox" id="budget-status-toggle" checked>
              <span class="admin-slider"></span>
            </label>
          </div>
          <div style="font-size: 0.75rem; color: #64748b; margin-top: 0.8rem; line-height: 1.4;">ปิดเพื่อแสดงข้อความ "อยู่ระหว่างปรับปรุง" ในหน้าข้อมูลวิทยาลัย</div>
        </div>
      </div>

      <div class="admin-card" style="padding: 0;">
        <div class="table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width: 80px;">ปีงบฯ</th>
                <th>รายการงบประมาณ / โครงการ</th>
                <th style="width: 140px;">หมวดหมู่</th>
                <th style="width: 160px;">จำนวนเงิน</th>
                <th style="width: 150px;">สถานะ</th>
                <th style="width: 100px; text-align: center;">จัดการ</th>
              </tr>
            </thead>
            <tbody id="budget-list-container">
              <!-- Dynamically populated -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Corrected Budget Modal using modal-overlay -->
      <div id="budget-modal" class="modal-overlay">
        <div class="modal-content" style="max-width: 600px;">
          <div class="modal-header">
            <h3 id="budget-modal-title">จัดการข้อมูล</h3>
            <button type="button" class="modal-close-btn" id="budget-modal-close-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
          <div class="modal-body">
            <form id="budget-form">
              <input type="hidden" id="budget-id" />
              
              <div class="form-grid">
                <div class="form-group">
                  <label for="budget-year">ปีงบประมาณ <span style="color:red;">*</span></label>
                  <input id="budget-year" type="number" class="form-control" required placeholder="เช่น 2567" />
                </div>

                <div class="form-group">
                  <label for="budget-category">หมวดหมู่งบประมาณ</label>
                  <select id="budget-category" class="form-control" required>
                    <option value="งบดำเนินงาน">งบดำเนินงาน</option>
                    <option value="งบลงทุน">งบลงทุน</option>
                    <option value="งบอุดหนุน">งบอุดหนุน</option>
                    <option value="งบรายจ่ายอื่น">งบรายจ่ายอื่น</option>
                  </select>
                </div>

                <div class="form-group form-full">
                  <label for="budget-title">ชื่อรายการ/โครงการ <span style="color:red;">*</span></label>
                  <input id="budget-title" type="text" class="form-control" required placeholder="กรอกชื่อโครงการ" />
                </div>

                <div class="form-group">
                  <label for="budget-amount">จำนวนเงิน (บาท) <span style="color:red;">*</span></label>
                  <input id="budget-amount" type="number" step="0.01" class="form-control" required placeholder="0.00" />
                </div>

                <div class="form-group">
                  <label for="budget-status">สถานะการดำเนินงาน</label>
                  <select id="budget-status" class="form-control" required>
                    <option value="รอดำเนินการ">รอดำเนินการ</option>
                    <option value="กำลังดำเนินการ">กำลังดำเนินการ</option>
                    <option value="ดำเนินการเสร็จสิ้น">ดำเนินการเสร็จสิ้น</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                  </select>
                </div>
              </div>

              <div class="form-actions mt-3">
                <button type="button" id="budget-cancel-btn" class="btn-outline">ยกเลิก</button>
                <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>


    <!-- ========================= IMAGES PANEL ========================= -->
    <section id="images-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>จัดการรูปภาพเว็บไซต์</h1>
          <p>อัปโหลดและจัดการภาพ Hero และ Sub-Banner Slideshow</p>
        </div>
      </div>

      <!-- Hero Image Card -->
      <div class="admin-card mb-2">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
          <div>
            <h3 style="margin:0;">🏔️ ภาพพื้นหลัง Hero</h3>
            <p class="text-muted" style="margin:0.25rem 0 0;">ภาพที่แสดงเมื่อ hover บนส่วน Hero ของหน้าหลัก</p>
          </div>
          <label for="hero-upload-input" class="btn-accent" style="cursor:pointer; display:inline-flex; align-items:center; gap:0.4rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            อัปโหลดภาพใหม่
          </label>
          <input type="file" id="hero-upload-input" accept="image/*" style="display:none;" />
        </div>
        <div id="hero-images-grid" style="display:flex; flex-wrap:wrap; gap:1rem;">
          <div style="text-align:center; color:var(--color-text-secondary); padding: 2rem 0; width:100%;">กำลังโหลด...</div>
        </div>
      </div>

      <!-- Sub-Banner Slideshow Card -->
      <div class="admin-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
          <div>
            <h3 style="margin:0;">🎞️ รูป Sub-Banner Slideshow</h3>
            <p class="text-muted" style="margin:0.25rem 0 0;">สไลด์โชว์ที่แสดงใต้เมนูลัด — รองรับหลายภาพ สลับอัตโนมัติ</p>
          </div>
          <label for="subbanner-upload-input" class="btn-accent" style="cursor:pointer; display:inline-flex; align-items:center; gap:0.4rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            + เพิ่มรูปภาพ
          </label>
          <input type="file" id="subbanner-upload-input" accept="image/*" style="display:none;" />
        </div>
        <div id="subbanner-images-grid" style="display:flex; flex-wrap:wrap; gap:1rem;">
          <div style="text-align:center; color:var(--color-text-secondary); padding: 2rem 0; width:100%;">กำลังโหลด...</div>
        </div>
      </div>
    </section>

    <!-- ========================= ACHIEVEMENTS PANEL ========================= -->
    <section id="achievements-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>ผลงานเด่นของวิทยาลัย</h1>
          <p>จัดการการ์ดผลงานและความสำเร็จ เพื่อแสดงในส่วน "ผลงานเด่น" หน้าหลัก</p>
        </div>
        <button id="achieve-add-btn" class="btn-accent">+ เพิ่มผลงาน</button>
      </div>

      <!-- Achievement Form (Modal-like card) -->
      <div id="achieve-form-container" class="admin-card hide">
        <h3 id="achieve-form-title" class="mb-2">เพิ่มผลงานเด่น</h3>
        <form id="achieve-form" enctype="multipart/form-data">
          <input type="hidden" id="achieve-id" />
          <div class="form-grid">
            <div class="form-group form-full">
              <label for="achieve-title">หัวข้อผลงาน *</label>
              <input id="achieve-title" name="title" type="text" class="form-control" required />
            </div>

            <div class="form-group form-full">
              <label for="achieve-description">คำอธิบายสั้นๆ *</label>
              <textarea id="achieve-description" name="description" class="form-control" rows="2" required></textarea>
            </div>

            <div class="form-group">
              <label for="achieve-awardLabel">ป้ายรางวัล (เช่น รางวัลชนะเลิศ)</label>
              <input id="achieve-awardLabel" name="awardLabel" type="text" class="form-control" />
            </div>

            <div class="form-group">
              <label for="achieve-awardText">รายละเอียดรางวัล (เช่น ผลงานเตาแก๊ส...)</label>
              <input id="achieve-awardText" name="awardText" type="text" class="form-control" />
            </div>

            <div class="form-group">
              <label for="achieve-order">ลำดับการแสดงผล</label>
              <input id="achieve-order" name="order" type="number" class="form-control" value="0" />
            </div>

            <div class="form-group">
              <label for="achieve-image">รูปภาพประกอบ (ถ้ามี)</label>
              <input id="achieve-image" name="image" type="file" accept="image/*" class="form-control file-input" />
              <small class="text-muted">หากไม่ใส่รูป ระบบจะใช้ไอคอนมาตรฐานตามลำดับ</small>
            </div>
          </div>
          <div class="form-actions mt-2">
            <button type="button" id="achieve-cancel-btn" class="btn-outline">ยกเลิก</button>
            <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
          </div>
        </form>
      </div>

      <!-- Achievement List -->
      <div class="admin-card">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width: 80px;">ลำดับ</th>
                <th>รูป</th>
                <th>หัวข้อ</th>
                <th>คำอธิบาย</th>
                <th style="text-align:right;">จัดการ</th>
              </tr>
            </thead>
            <tbody id="achieve-tbody">
              <tr><td colspan="5" style="text-align:center;">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========================= FAQ PANEL ========================= -->
    <section id="faq-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>จัดการ FAQ (คำถามที่พบบ่อย)</h1>
          <p>จัดการคำถามและคำตอบที่จะแสดงในหน้าแรกของเว็บไซต์</p>
        </div>
        <button id="faq-add-btn" class="btn-accent">+ เพิ่ม FAQ</button>
      </div>

      <!-- FAQ Form (Modal-like card) -->
      <div id="faq-form-container" class="admin-card hide">
        <h3 id="faq-form-title" class="mb-2">เพิ่มคำถามใหม่</h3>
        <form id="faq-form">
          <input type="hidden" id="faq-id" />
          <div class="form-grid">
            <div class="form-group form-full">
              <label for="faq-question">คำถาม *</label>
              <input id="faq-question" name="question" type="text" class="form-control" required />
            </div>

            <div class="form-group form-full">
              <label for="faq-answer">คำตอบ *</label>
              <textarea id="faq-answer" name="answer" class="form-control" rows="3" required></textarea>
            </div>

            <div class="form-group" style="display:none;">
              <label for="faq-category">หมวดหมู่</label>
              <input id="faq-category" name="category" type="text" class="form-control" value="ทั่วไป" />
            </div>

            <div class="form-group">
              <label for="faq-order">ลำดับการแสดงผล</label>
              <input id="faq-order" name="order" type="number" class="form-control" value="0" />
            </div>
          </div>
          <div class="form-actions mt-2">
            <button type="button" id="faq-cancel-btn" class="btn-outline">ยกเลิก</button>
            <button type="submit" class="btn-accent">บันทึกข้อมูล</button>
          </div>
        </form>
      </div>

      <!-- FAQ List -->
      <div class="admin-card">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width: 80px;">ลำดับ</th>
                <th style="width: 150px;">หมวดหมู่</th>
                <th>คำถาม</th>
                <th style="text-align:right;">จัดการ</th>
              </tr>
            </thead>
            <tbody id="faq-tbody">
              <tr><td colspan="4" style="text-align:center;">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========================= OTHERS PANEL ========================= -->
    <section id="others-panel" class="admin-panel hide">
      <div class="panel-header">
        <div>
          <h1>ระบบอื่นๆ</h1>
          <p>ส่วนขยายสำหรับอนาคต</p>
        </div>
      </div>
      <div class="admin-card" style="text-align:center; padding: 4rem 2rem;">
        <h2 style="color:var(--color-text-secondary); margin-bottom: 1rem;">หน้านี้ยังไม่เปิดใช้งาน</h2>
        <p class="text-muted">กำลังเตรียมระบบสำหรับฟีเจอร์ใหม่ๆ ในการอัปเดตครั้งถัดไป</p>
      </div>
    </section>

  </main>
</div>

<script src="/js/admin.js"></script>
<script src="/js/curriculum-admin.js"></script>
</body>
</html>
