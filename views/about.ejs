<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="วิทยาลัยการอาชีพบ่อไร่ - ข้อมูลพื้นฐานและประวัติสถานศึกษาตามมาตรฐานอาชีวศึกษา" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --a-purple: #7042f8;
      --a-blue: #0ea5e9;
      --a-pink: #ec4899;
      --a-dark: #0f0c29;
      --a-mid: #302b63;
      --a-text: #0f172a;
      --a-muted: #64748b;
      --a-border: rgba(112, 66, 248, 0.1);
      --sidebar-w: 240px;
    }

    body {
      font-family: 'Sarabun', sans-serif;
      scroll-behavior: smooth;
      background: #f8fafc;
    }

    /* ═══ HERO — Light Theme ════════════════════════════════════════════ */
    .about-hero {
      width: 100%;
      min-height: 480px;
      position: relative;
      background: linear-gradient(160deg, #f8f5ff 0%, #eef6ff 50%, #f0f9ff 100%);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: var(--a-text);
      border-bottom: 1px solid rgba(112, 66, 248, 0.1);
    }

    /* Decorative rings */
    .hero-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(112, 66, 248, 0.12);
      pointer-events: none;
    }

    .ring-1 {
      width: 460px;
      height: 460px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: ringPulse 6s ease-in-out infinite;
    }

    .ring-2 {
      width: 700px;
      height: 700px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: ringPulse 9s ease-in-out infinite 1.5s;
    }

    .ring-3 {
      width: 960px;
      height: 960px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: ringPulse 12s ease-in-out infinite 3s;
    }

    @keyframes ringPulse {

      0%,
      100% {
        opacity: 0.5;
      }

      50% {
        opacity: 1;
      }
    }

    /* Soft orbs */
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      pointer-events: none;
    }

    .orb-1 {
      width: 400px;
      height: 400px;
      background: rgba(112, 66, 248, 0.12);
      top: -80px;
      left: -60px;
      animation: floatA 9s ease-in-out infinite;
    }

    .orb-2 {
      width: 360px;
      height: 360px;
      background: rgba(14, 165, 233, 0.1);
      bottom: -60px;
      right: -40px;
      animation: floatA 11s ease-in-out infinite reverse;
    }

    .orb-3 {
      width: 260px;
      height: 260px;
      background: rgba(236, 72, 153, 0.07);
      top: 50%;
      left: 50%;
      animation: floatB 13s ease-in-out infinite 2s;
    }

    @keyframes floatA {

      0%,
      100% {
        transform: translate(0, 0);
      }

      50% {
        transform: translate(30px, -30px);
      }
    }

    @keyframes floatB {

      0%,
      100% {
        transform: translate(-50%, -50%);
      }

      50% {
        transform: translate(calc(-50% + 20px), calc(-50% - 20px));
      }
    }

    .about-hero-content {
      position: relative;
      z-index: 10;
      padding: 100px 24px 60px;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 18px;
      background: rgba(112, 66, 248, 0.07);
      border: 1px solid rgba(112, 66, 248, 0.2);
      border-radius: 100px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 24px;
      color: var(--a-purple);
    }

    .hero-tag::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--a-blue);
      border-radius: 50%;
      animation: blink 2s ease-in-out infinite;
    }

    @keyframes blink {

      0%,
      100% {
        opacity: 1;
      }

      50% {
        opacity: .3;
      }
    }

    .hero-title {
      font-size: clamp(2.5rem, 6vw, 4.2rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 18px;
      letter-spacing: -1px;
      color: #0f172a;
    }

    .hero-title .hl {
      background: linear-gradient(90deg, var(--a-purple), var(--a-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: var(--a-muted);
      max-width: 540px;
      margin: 0 auto 28px;
      line-height: 1.7;
    }

    .hero-breadcrumb {
      font-size: .85rem;
      color: var(--a-muted);
      opacity: 0.7;
    }

    .hero-breadcrumb a {
      color: var(--a-purple);
      text-decoration: none;
    }

    .hero-breadcrumb span {
      margin: 0 8px;
    }

    /* ═══ STAT BAR (floating) ════════════════════════════════════════════ */
    .stat-bar {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(20px);
      border: 1px solid var(--a-border);
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(31, 38, 135, 0.10);
      max-width: 900px;
      margin: -44px auto 0;
      padding: 26px 40px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      position: relative;
      z-index: 30;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 3px;
    }

    .stat-item:not(:last-child) {
      border-right: 1px solid var(--a-border);
    }

    .stat-value {
      font-size: 1.9rem;
      font-weight: 900;
      background: linear-gradient(135deg, var(--a-purple), var(--a-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
    }

    .stat-label {
      font-size: .78rem;
      color: var(--a-muted);
      font-weight: 500;
    }

    /* ═══ PAGE LAYOUT ════════════════════════════════════════════════════ */
    .about-layout {
      max-width: 1300px;
      margin: 0 auto;
      padding: 60px 24px 100px;
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      gap: 48px;
      align-items: start;
    }

    /* ═══ SIDEBAR ════════════════════════════════════════════════════════ */
    .about-sidebar {
      position: sticky;
      top: 100px;
      background: #fff;
      border: 1px solid var(--a-border);
      border-radius: 20px;
      padding: 24px 16px;
      box-shadow: 0 8px 30px rgba(112, 66, 248, 0.06);
    }

    .sidebar-heading {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--a-purple);
      padding: 0 8px 12px;
      border-bottom: 1px solid var(--a-border);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sidebar-heading::before {
      content: '';
      width: 3px;
      height: 14px;
      background: linear-gradient(to bottom, var(--a-purple), var(--a-blue));
      border-radius: 2px;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 12px;
      text-decoration: none;
      color: var(--a-muted);
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.25s ease;
      border-left: 2px solid transparent;
      margin-bottom: 2px;
    }

    .sidebar-link .s-icon {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
      opacity: 0.6;
      transition: opacity 0.25s;
    }

    .sidebar-link:hover {
      background: rgba(112, 66, 248, 0.06);
      color: var(--a-purple);
      border-left-color: var(--a-purple);
    }

    .sidebar-link:hover .s-icon {
      opacity: 1;
    }

    .sidebar-link.active {
      background: rgba(112, 66, 248, 0.08);
      color: var(--a-purple);
      font-weight: 700;
      border-left-color: var(--a-purple);
    }

    .sidebar-link.active .s-icon {
      opacity: 1;
    }

    /* ═══ MAIN CONTENT ═══════════════════════════════════════════════════ */
    .about-article {
      display: flex;
      flex-direction: column;
      gap: 60px;
    }

    .info-section {
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 56px;
      scroll-margin-top: 100px;
    }

    .info-section:last-child {
      border-bottom: none;
    }

    /* Section header */
    .section-label {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 6px;
    }

    .section-eyebrow {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--a-purple);
    }

    .section-accent-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--a-blue);
    }

    .section-h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 800;
      color: var(--a-text);
      line-height: 1.2;
      margin-bottom: 20px;
    }

    .section-body {
      color: var(--a-muted);
      font-size: 1rem;
      line-height: 1.8;
    }

    .section-body p {
      margin-bottom: 16px;
    }

    /* Two-column split inside a section */
    .split-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
      align-items: flex-start;
    }

    .split-visual-box {
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--a-border);
      background: #f8fafc;
      box-shadow: 0 8px 30px rgba(112, 66, 248, 0.06);
    }

    .split-visual-box img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.5s ease;
    }

    .split-visual-box:hover img {
      transform: scale(1.04);
    }

    /* Vision/mission cards */
    .vm-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 20px 0;
    }

    .vm-card {
      padding: 20px;
      border-radius: 16px;
      background: #fff;
      border-left: 4px solid var(--a-purple);
      box-shadow: 0 4px 16px rgba(31, 38, 135, 0.05);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .vm-card:nth-child(2) {
      border-left-color: var(--a-blue);
    }

    .vm-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 24px rgba(112, 66, 248, 0.1);
    }

    .vm-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--a-purple);
      margin-bottom: 6px;
    }

    .vm-card:nth-child(2) .vm-label {
      color: var(--a-blue);
    }

    .vm-text {
      font-size: 1rem;
      font-weight: 700;
      color: var(--a-text);
      line-height: 1.4;
    }

    /* Quick facts */
    .facts-row {
      display: flex;
      gap: 0;
      margin: 24px 0 0;
      border: 1px solid var(--a-border);
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
    }

    .fact-block {
      flex: 1;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 3px;
      text-align: center;
    }

    .fact-block:not(:last-child) {
      border-right: 1px solid var(--a-border);
    }

    .fact-val {
      font-size: 1.25rem;
      font-weight: 900;
      color: var(--a-purple);
    }

    .fact-lbl {
      font-size: 0.72rem;
      color: var(--a-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Data tables */
    .data-wrap {
      margin: 20px 0;
      border-radius: 16px;
      overflow-x: auto;
      border: 1px solid var(--a-border);
      box-shadow: 0 4px 16px rgba(31, 38, 135, 0.04);
      scrollbar-width: thin;
      scrollbar-color: var(--a-purple) transparent;
    }

    .data-wrap::-webkit-scrollbar {
      height: 6px;
    }

    .data-wrap::-webkit-scrollbar-thumb {
      background: var(--a-purple);
      border-radius: 10px;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
    }

    .data-table th {
      background: linear-gradient(90deg, var(--a-purple), #5a32d0);
      color: #fff;
      font-size: 0.82rem;
      font-weight: 700;
      padding: 12px 18px;
      text-align: left;
      letter-spacing: 0.04em;
    }

    .data-table td {
      padding: 12px 18px;
      font-size: 0.95rem;
      color: var(--a-muted);
      border-bottom: 1px solid #f1f5f9;
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .data-table tr:hover td {
      background: #fdfaff;
      color: var(--a-purple);
    }

    .intern-highlight {
      background: #f0fdf4 !important;
      color: #059669 !important;
      font-weight: 700;
      position: relative;
    }

    .intern-highlight::after {
      content: 'ฝึกงาน';
      position: absolute;
      top: -2px;
      right: 2px;
      font-size: 0.5rem;
      background: #10b981;
      color: #fff;
      padding: 1px 4px;
      border-radius: 4px;
      font-weight: 800;
      opacity: 0.8;
    }

    /* Asset list (chips) */
    .asset-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
      margin: 20px 0;
    }

    .asset-chip {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 18px;
      background: #fff;
      border: 1px solid var(--a-border);
      border-radius: 14px;
      font-size: 0.9rem;
      color: var(--a-text);
      font-weight: 500;
      transition: all 0.3s ease;
      box-shadow: 0 2px 10px rgba(112, 66, 248, 0.04);
    }

    .asset-chip:hover {
      border-color: var(--a-purple);
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(112, 66, 248, 0.1);
    }

    .chip-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--a-purple), var(--a-blue));
      flex-shrink: 0;
    }

    /* Partner chips */
    .partner-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 20px;
    }

    .partner-chip {
      padding: 8px 20px;
      background: linear-gradient(135deg, rgba(112, 66, 248, 0.07), rgba(14, 165, 233, 0.05));
      border: 1px solid rgba(112, 66, 248, 0.15);
      border-radius: 100px;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--a-purple);
    }

    /* SVG placeholder visual */
    .icon-visual {
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 180px;
    }

    /* Back button */
    .back-wrap {
      text-align: center;
      padding-top: 40px;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      background: #fff;
      border: 1px solid var(--a-border);
      border-radius: 100px;
      color: var(--a-purple);
      font-weight: 700;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(112, 66, 248, 0.08);
    }

    .back-btn:hover {
      background: var(--a-purple);
      color: #fff;
      transform: translateX(-4px);
    }

    /* Reveal */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ═══ MANAGEMENT SECTION ════════════════════════════════════════════ */
    .mgmt-section {
      margin-top: 40px;
      padding: 30px;
      background: linear-gradient(135deg, #f8fafc, #f1f5f9);
      border-radius: 24px;
      border: 1px solid var(--a-border);
    }

    .mgmt-h3 {
      font-size: 0.95rem;
      font-weight: 800;
      color: var(--a-purple);
      margin-bottom: 24px;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .mgmt-grid {
      display: flex;
      flex-direction: column;
      gap: 24px;
      align-items: center;
    }

    .mgmt-card {
      background: #fff;
      border-radius: 20px;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 10px 25px rgba(112, 66, 248, 0.05);
      border: 1px solid #edf2f7;
      transition: transform 0.3s ease;
    }

    .mgmt-card:hover {
      transform: translateY(-3px);
    }

    .mgmt-img {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--a-purple);
      background: #fff;
    }

    .mgmt-info {
      flex: 1;
    }

    .mgmt-name {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--a-text);
      line-height: 1.2;
    }

    .mgmt-pos {
      font-size: 0.75rem;
      color: var(--a-muted);
      font-weight: 600;
      margin-top: 4px;
    }

    .mgmt-deputies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
      width: 100%;
    }

    .mgmt-card.is-deputy {
      max-width: none;
      padding: 12px 16px;
    }

    .mgmt-card.is-deputy .mgmt-img {
      width: 48px;
      height: 48px;
      border-color: var(--a-blue);
    }

    .mgmt-card.is-deputy .mgmt-name {
      font-size: 0.9rem;
    }

    /* Contact badges */
    .mgmt-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 8px;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.7rem;
      color: var(--a-purple);
      background: rgba(112, 66, 248, 0.05);
      padding: 4px 10px;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s;
    }

    .contact-item:hover {
      background: var(--a-purple);
      color: #fff;
    }

    .contact-item svg {
      width: 12px;
      height: 12px;
    }

    /* Identity Box (Right Column) */
    .identity-container {
      margin-top: 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .identity-box {
      background: #fff;
      border: 1px solid var(--a-border);
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 8px 30px rgba(112, 66, 248, 0.06);
      position: relative;
      overflow: hidden;
      z-index: 1;
    }

    .id-ruby-thumb {
      width: 64px;
      height: 64px;
      object-fit: contain;
      border-radius: 12px;
      background: #fdf2f2;
      padding: 6px;
      border: 1px solid rgba(146, 16, 16, 0.15);
      margin-left: 4px;
      box-shadow: 0 6px 15px rgba(146, 16, 16, 0.12);
    }

    .id-header {
      font-size: 0.72rem;
      font-weight: 800;
      color: var(--a-purple);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .id-header::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, var(--a-border), transparent);
    }

    .id-logo-wrap {
      display: flex;
      justify-content: center;
      padding: 10px 0 20px;
    }

    .id-logo {
      width: 100px;
      height: auto;
      filter: drop-shadow(0 4px 12px rgba(112, 66, 248, 0.15));
    }

    .id-row {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 12px 0;
      border-top: 1px solid #f1f5f9;
    }

    .id-lbl {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--a-text);
      width: 100px;
      flex-shrink: 0;
    }

    .id-val {
      font-size: 0.88rem;
      color: var(--a-muted);
      line-height: 1.5;
    }

    .id-color-swatch {
      display: flex;
      gap: 8px;
    }

    .swatch {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      border: 1px solid #e2e8f0;
    }

    .sw-purple {
      background: #921010;
    }

    /* Ruby Red specifically for identity */
    .sw-white {
      background: #ffffff;
    }

    /* ═══ RESPONSIVE ═════════════════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .about-layout {
        grid-template-columns: 1fr;
        padding-top: 40px;
      }

      .about-sidebar {
        position: static;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 14px;
        background: #fff;
      }

      .sidebar-heading {
        width: 100%;
        margin-bottom: 6px;
      }

      .sidebar-link {
        flex: auto;
        justify-content: center;
        border-left: none;
        border-bottom: 2px solid transparent;
        border-radius: 10px;
      }

      .sidebar-link.active {
        border-left: none;
        border-bottom-color: var(--a-purple);
      }
    }

    @media (max-width: 768px) {
      .split-layout {
        grid-template-columns: 1fr;
      }

      .vm-grid {
        grid-template-columns: 1fr;
      }

      .stat-bar {
        grid-template-columns: 1fr;
        padding: 20px;
      }

      .stat-item:not(:last-child) {
        border-right: none;
        border-bottom: 1px solid var(--a-border);
        padding-bottom: 14px;
      }

      .facts-row {
        flex-direction: column;
      }

      .fact-block:not(:last-child) {
        border-right: none;
        border-bottom: 1px solid var(--a-border);
      }
    }

    /* ══ SUMMARY TABLE ══ */
    .summary-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid var(--a-border);
      padding: 0;
      box-shadow: 0 4px 16px rgba(31, 38, 135, 0.04);
      overflow: hidden;
      margin-top: 16px;
    }

    .summary-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .summary-table th {
      background: #f8fafc;
      padding: 16px 20px;
      font-size: 0.85rem;
      font-weight: 800;
      color: var(--a-muted);
      border-bottom: 2px solid var(--a-border);
    }

    .summary-table td {
      padding: 14px 20px;
      border-bottom: 1px solid var(--a-border);
      font-size: 0.95rem;
      color: var(--a-text);
      font-weight: 600;
    }

    .summary-table tbody tr {
      transition: background 0.2s;
    }

    .summary-table tbody tr:hover {
      background: #fdfcff;
    }

    .summary-table tbody tr:last-child td {
      border-bottom: none;
    }

    .sum-pos-label {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sum-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--a-purple), var(--a-blue));
    }

    .summary-table tfoot td {
      background: #f8fafc;
      padding: 18px 20px;
      border-top: 2px solid #e2e8f0;
      border-bottom: none;
    }
    .budget-card {
      transition: all 0.3s ease;
    }

    .budget-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 24px rgba(112, 66, 248, 0.08);
    }

    .doc-link:hover {
      background: #fff !important;
      border-color: var(--a-purple) !important;
      transform: translateX(4px);
    }

    /* Facility Accordion Styles */
    .facility-accordion {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 2rem;
    }

    .fac-acc-item {
      background: #fff;
      border: 1px solid var(--a-border);
      border-radius: 20px;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .fac-acc-item.active {
      border-color: var(--a-purple);
      box-shadow: 0 10px 30px rgba(112, 66, 248, 0.08);
      transform: translateY(-2px);
    }

    .fac-acc-header {
      padding: 20px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      cursor: pointer;
      user-select: none;
      transition: all 0.2s;
    }

    .fac-acc-header:hover {
      background: #fafafa;
    }

    .fac-acc-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.3s;
    }

    .fac-acc-item.active .fac-acc-icon {
      transform: scale(1.1);
    }

    .fac-acc-title-wrap {
      flex: 1;
    }

    .fac-acc-title {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--a-text);
      display: block;
      margin-bottom: 2px;
    }

    .fac-acc-subtitle {
      font-size: 0.75rem;
      color: var(--a-muted);
      font-weight: 600;
      display: block;
    }

    .fac-acc-arrow {
      color: var(--a-muted);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .fac-acc-item.active .fac-acc-arrow {
      transform: rotate(180deg);
      color: var(--a-purple);
    }

    .fac-acc-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), padding 0.4s;
      padding: 0 24px;
    }

    .fac-acc-item.active .fac-acc-content {
      max-height: 500px;
      padding-bottom: 24px;
    }

    .fac-detail-card {
      padding: 16px;
      background: #f8fafc;
      border-radius: 16px;
      border: 1px solid #f1f5f9;
      margin-bottom: 12px;
      transition: all 0.2s;
    }

    .fac-detail-card:hover {
      background: #fff;
      border-color: var(--a-purple);
      box-shadow: 0 4px 12px rgba(112, 66, 248, 0.05);
    }

    .fac-detail-card:last-child {
      margin-bottom: 0;
    }
  </style>
</head>

