<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
    content="ฐานข้อมูลสารสนเทศวิทยาลัยการอาชีพบ่อไร่ - ข้อมูลพื้นฐาน 9 ประการตามมาตรฐานอาชีวศึกษา" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --sidebar-width: 240px;
      --accent-color: #6b21a8;
      --accent-light: #9333ea;
      --text-main: #1e293b;
      --text-muted: #475569;
      --bg-page: #ffffff;
      --bg-sidebar: #f8fafc;
      --glass-border: rgba(107, 33, 168, 0.1);
    }

    body {
      font-family: 'Sarabun', sans-serif;
      scroll-behavior: smooth;
    }

    /* Layout Structure */
    .about-main-container {
      display: flex;
      flex-direction: row-reverse;
      max-width: 1400px;
      margin: 0 auto;
      padding: 60px 60px 80px;
      /* Reduced top padding as banner is now above */
      gap: 60px;
      position: relative;
    }

    /* Hero Banner */
    .about-hero {
      width: 100%;
      height: 450px;
      position: relative;
      background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 100%);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #ffffff;
    }

    .about-hero-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .about-hero-content {
      position: relative;
      z-index: 10;
      padding: 0 20px;
    }

    .about-hero-tag {
      display: inline-block;
      padding: 6px 16px;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 100px;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 20px;
      color: #e9d5ff;
    }

    .about-hero-title {
      font-size: 4rem;
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 15px;
      text-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .about-hero-subtitle {
      font-size: 1.25rem;
      font-weight: 400;
      opacity: 0.9;
      max-width: 600px;
      margin: 0 auto;
    }

    .about-hero-breadcrumb {
      margin-top: 30px;
      font-size: 0.9rem;
      opacity: 0.7;
    }

    .about-hero-breadcrumb a {
      color: #fff;
      text-decoration: none;
    }

    .about-hero-breadcrumb span {
      margin: 0 10px;
    }

    /* Sticky Sidebar */
    .about-sidebar {
      width: var(--sidebar-width);
      height: fit-content;
      position: sticky;
      top: 100px;
      padding: 20px;
      background: var(--bg-sidebar);
      backdrop-filter: blur(10px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      box-shadow: 0 10px 30px rgba(107, 33, 168, 0.05);
    }

    .sidebar-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--accent-color);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sidebar-title::before {
      content: '';
      width: 4px;
      height: 18px;
      background: var(--accent-color);
      border-radius: 2px;
    }

    .sidebar-link {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      padding: 6px 12px;
      border-radius: 10px;
      transition: all 0.3s ease;
      display: block;
      border-left: 2px solid transparent;
      white-space: normal;
      line-height: 1.4;
    }

    .sidebar-link:hover {
      background: rgba(112, 66, 248, 0.1);
      color: var(--accent-color);
    }

    .sidebar-link.active {
      background: rgba(107, 33, 168, 0.08);
      color: var(--accent-color);
      border-left-color: var(--accent-color);
      font-weight: 600;
    }

    /* Content Area */
    .about-content-article {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 70px;
      padding-left: 40px;
      /* Specific left breathing room for the article */
    }

    .info-section {
      scroll-margin-top: 20px;
      /* Adjusted as menu is sticky but header is above */
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 50px;
    }

    .info-section:last-child {
      border-bottom: none;
    }

    /* Split Layout */
    .section-split {
      display: flex;
      gap: 40px;
      align-items: flex-start;
    }

    .split-text {
      flex: 1.2;
    }

    .split-visual {
      flex: 0.8;
      position: relative;
    }

    .visual-frame {
      width: 100%;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 15px 35px rgba(107, 33, 168, 0.1);
      border: 1px solid var(--glass-border);
      background: #f8fafc;
    }

    .visual-frame img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.6s ease;
    }

    .visual-frame:hover img {
      transform: scale(1.05);
    }

    /* Decoration Accents */
    .decor-title-accent {
      width: 40px;
      height: 4px;
      background: var(--gradient-main);
      border-radius: 2px;
      margin-bottom: 15px;
    }

    .section-header {
      margin-bottom: 40px;
    }

    .section-tag {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 700;
      margin-bottom: 15px;
      display: block;
    }

    .section-title-large {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--text-main);
      line-height: 1.2;
    }

    .content-block {
      color: var(--text-muted);
      line-height: 1.8;
      font-size: 1.1rem;
    }

    .content-block p {
      margin-bottom: 25px;
    }

    /* Structured Data: Tables */
    .data-table-container {
      margin: 30px 0;
      overflow-x: auto;
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .data-table th,
    .data-table td {
      padding: 12px 20px;
      border-bottom: 1px solid #f1f5f9;
    }

    .data-table th {
      background: linear-gradient(to right, #6b21a8, #9333ea);
      color: #fff;
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
    }

    .data-table td {
      color: var(--text-muted);
      font-size: 1rem;
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .data-table tr:hover td {
      background: #fdfaff;
      color: var(--accent-color);
    }

    /* Structured Data: Lists */
    .asset-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin: 30px 0;
    }

    .asset-item {
      padding: 20px;
      background: #fbf9ff;
      border-radius: 16px;
      border: 1px solid var(--glass-border);
      display: flex;
      align-items: center;
      gap: 15px;
      transition: all 0.3s ease;
    }

    .asset-item:hover {
      border-color: var(--accent-color);
      transform: translateY(-3px);
      box-shadow: 0 5px 15px rgba(107, 33, 168, 0.1);
    }

    .asset-dot {
      width: 8px;
      height: 8px;
      background: var(--accent-color);
      border-radius: 50%;
    }

    .news-widget {
      display: none;
    }

    /* Repurposed Sidebar Link Style */
    .sidebar-link {
      display: flex;
      gap: 10px;
      padding: 6px 10px;
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.3s ease;
      color: var(--text-main);
      align-items: center;
      margin-bottom: 2px;
    }

    .sidebar-link:hover {
      background: rgba(107, 33, 168, 0.05);
      color: var(--accent-color);
    }

    .sidebar-link.active {
      background: rgba(107, 33, 168, 0.08);
      color: var(--accent-color);
    }

    .sidebar-link.active .link-icon-wrap {
      color: var(--accent-color);
      transform: scale(1.1);
    }

    .sidebar-link.active .link-text {
      color: var(--accent-color);
      font-weight: 700;
    }

    .link-icon-wrap {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.3s ease;
      color: var(--text-muted);
    }

    .link-text {
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-muted);
      line-height: 1.2;
    }

    /* Quick Facts Bar */
    .quick-facts-bar {
      display: flex;
      gap: 25px;
      margin-top: 30px;
      padding: 20px;
      background: #f8fafc;
      border-radius: 16px;
      border: 1px solid var(--glass-border);
    }

    .fact-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .fact-value {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--accent-color);
    }

    .fact-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Vision Card */
    .vision-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 30px;
    }

    .vision-card {
      padding: 20px;
      background: #ffffff;
      border-left: 4px solid var(--accent-color);
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
      transition: all 0.3s ease;
    }

    .vision-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(107, 33, 168, 0.08);
    }

    .vision-card.secondary {
      border-left-color: #0ea5e9;
    }

    .vision-card h4 {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .vision-card p {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-main);
      line-height: 1.4;
      margin: 0;
    }

    /* Reveal Settings */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease-out;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Mobile Compatibility */
    @media (max-width: 992px) {
      .about-main-container {
        flex-direction: column;
        padding-top: 100px;
      }

      .about-sidebar {
        width: 100%;
        position: static;
        top: 0;
        overflow-x: auto;
        flex-direction: row;
        white-space: nowrap;
        padding: 15px;
      }

      .section-title-large {
        font-size: 2rem;
      }
    }

    .back-btn-wrap {
      text-align: center;
      margin-top: 80px;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: #fff;
      border: 1px solid var(--glass-border);
      border-radius: 50px;
      color: var(--accent-color);
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(107, 33, 168, 0.1);
    }

    .back-btn:hover {
      background: var(--accent-color);
      color: #fff;
      transform: translateX(-5px);
    }
  </style>
</head>

<body>

  <!-- Floating background — fixed behind all sections -->
  <div class="section-canvas-wrap">
    <canvas id="section-canvas"></canvas>
  </div>

  <%- include('partials/navbar') %>

    <!-- Section 0: Hero Banner -->
    <section class="about-hero">
      <canvas id="about-hero-canvas" class="about-hero-canvas"></canvas>
      <div class="about-hero-content reveal">
        <span class="about-hero-tag">College Information</span>
        <h1 class="about-hero-title">ข้อมูลสถานศึกษา</h1>
        <p class="about-hero-subtitle">Borai Industrial and Community Education College</p>
        <div class="about-hero-breadcrumb">
          <a href="/">หน้าแรก</a> <span>/</span> <span>ข้อมูลสถานศึกษา</span>
        </div>
      </div>
    </section>

    <div class="about-main-container">

      <!-- Sidebar Navigation -->
      <aside class="about-sidebar">
        <div class="sidebar-nav-group">
          <h3 class="sidebar-title">ฐานข้อมูล 9 ด้าน</h3>

          <a href="#college-profile" class="sidebar-link active">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลสถานศึกษา</span>
          </a>

          <a href="#student-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลนักเรียน/นศ.</span>
          </a>

          <a href="#staff-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลบุคลากร</span>
          </a>

          <a href="#curriculum-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลหลักสูตร</span>
          </a>

          <a href="#budget-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลงบประมาณ</span>
          </a>

          <a href="#asset-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path
                  d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลครุภัณฑ์</span>
          </a>

          <a href="#facility-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M9 3v18" />
                <path d="M15 3v18" />
                <path d="M3 9h18" />
                <path d="M3 15h18" />
              </svg>
            </div>
            <span class="link-text">ข้อมูลอาคารสถานที่</span>
          </a>

          <a href="#partner-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <polyline points="16 11 18 13 22 9" />
              </svg>
            </div>
            <span class="link-text">สถานประกอบการ</span>
          </a>

          <a href="#community-info" class="sidebar-link">
            <div class="link-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1-4-10z" />
              </svg>
            </div>
            <span class="link-text">บริบทชุมชน/ศก.</span>
          </a>
        </div>
      </aside>

      <main class="about-content-article">

        <!-- Section 1: ข้อมูลสถานศึกษา -->
        <section id="college-profile" class="info-section reveal">
          <div class="section-split">
            <div class="split-text">
              <header class="section-header">
                <div class="decor-title-accent"></div>
                <span class="section-tag">Academic Excellence</span>
                <h2 class="section-title-large">ประวัติวิทยาลัย</h2>
              </header>
              <div class="content-block">
                <p>วิทยาลัยฯ ประกาศจัดตั้งเมื่อวันที่ <strong>18 มิถุนายน พ.ศ. 2540</strong> ตั้งอยู่ที่ตำบลช้างทูน
                  อำเภอบ่อไร่ จังหวัดตราด เดิมพื้นที่แห่งนี้เรียกว่า “ทุ่งก๊าย”
                  ซึ่งเป็นพื้นที่ทางประวัติศาสตร์และเศรษฐกิจที่สำคัญของท้องถิ่น</p>

                <!-- Vision cards -->
                <div class="vision-container">
                  <div class="vision-card">
                    <h4>วิสัยทัศน์ (Vision)</h4>
                    <p>ผลิตพัฒนากำลังคนสู่ระดับสากล</p>
                  </div>
                  <div class="vision-card secondary">
                    <h4>ปรัชญา (Philosophy)</h4>
                    <p>ทักษะเยี่ยม เปี่ยมคุณธรรม ล้ำเทคโนโลยี</p>
                  </div>
                </div>

                <!-- Quick Facts bar -->
                <div class="quick-facts-bar">
                  <div class="fact-item">
                    <span class="fact-label">พื้นที่วิทยาลัย</span>
                    <span class="fact-value">100 ไร่ 2 งาน</span>
                  </div>
                  <div class="fact-item">
                    <span class="fact-label">ปีที่ก่อตั้ง</span>
                    <span class="fact-value">พ.ศ. 2540</span>
                  </div>
                  <div class="fact-item">
                    <span class="fact-label">ที่ตั้ง</span>
                    <span class="fact-value">ต.ช้างทูน</span>
                  </div>
                </div>

              </div>
            </div>
            <div class="split-visual">
              <div class="visual-frame">
                <img src="/images/college-hero.webp" alt="College Campus"
                  onerror="this.src='/images/college-about.png'">
              </div>
            </div>
          </div>
        </section>

        <!-- Section 2: ข้อมูลนักเรียน นักศึกษา -->
        <section id="student-info" class="info-section reveal">
          <header class="section-header">
            <div class="decor-title-accent" style="background: #0ea5e9;"></div>
            <span class="section-tag">Student Demographics</span>
            <h2 class="section-title-large">ข้อมูลนักเรียน นักศึกษา</h2>
