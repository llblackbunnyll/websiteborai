      <!-- ARTICLE -->
      <main class="about-article">

        <!-- 1. ข้อมูลสถานศึกษา -->
        <section id="college-profile" class="info-section reveal">
          <div class="split-layout">
            <div>
              <div class="section-label">
                <span class="section-eyebrow">Academic Excellence</span>
                <span class="section-accent-dot"></span>
              </div>
              <h2 class="section-h2">ประวัติวิทยาลัย</h2>
              <div class="section-body">
                <p>วิทยาลัยฯ ประกาศจัดตั้งเมื่อวันที่ <strong>18 มิถุนายน พ.ศ. 2540</strong> ตั้งอยู่ที่ตำบลช้างทูน
                  อำเภอบ่อไร่ จังหวัดตราด เดิมพื้นที่แห่งนี้เรียกว่า "ทุ่งก๊าย"
                  ซึ่งเป็นพื้นที่ทางประวัติศาสตร์และเศรษฐกิจที่สำคัญของท้องถิ่น</p>
              </div>

              <div class="facts-row">
                <div class="fact-block">
                  <span class="fact-val">100 ไร่ 2 งาน</span>
                  <span class="fact-lbl">พื้นที่วิทยาลัย</span>
                </div>
                <div class="fact-block">
                  <span class="fact-val">พ.ศ. 2540</span>
                  <span class="fact-lbl">ปีที่ก่อตั้ง</span>
                </div>
                <div class="fact-block">
                  <span class="fact-val">ต.ช้างทูน</span>
                  <span class="fact-lbl">ที่ตั้ง</span>
                </div>
              </div>

              <div class="vm-grid">
                <div class="vm-card">
                  <div class="vm-label">วิสัยทัศน์ (Vision)</div>
                  <div class="vm-text">ผลิตพัฒนากำลังคนสู่ระดับสากล</div>
                </div>
                <div class="vm-card">
                  <div class="vm-label">ปรัชญา (Philosophy)</div>
                  <div class="vm-text">มุ่งคุภาพเด่น เน้นคุณธรรม นำวิชาการ สร้างสรรค์ชุมชน</div>
                </div>
              </div>

              <!-- Management Section -->
              <% const findEx=(kw, dk)=> allPersonnel.find(p => {
                const dts = Array.isArray(p.duties) ? p.duties : (p.duties ? JSON.parse(p.duties) : []);
                const hay = ((p.position||'') + ' ' + dts.join(' ')).toLowerCase();
                return hay.includes(kw.toLowerCase()) && (!dk || hay.includes(dk.toLowerCase()));
                });
                const dir = allPersonnel.find(p => p.isDirector) || findEx('ผู้อำนวยการ');
                const dList = [
                { p: findEx('รองผู้อำนวยการ', 'บริหาร'), l: 'ฝ่ายบริหารทรัพยากร' },
                { p: findEx('รองผู้อำนวยการ', 'แผนงาน'), l: 'ฝ่ายยุทธศาสตร์และแผนงาน' },
                { p: findEx('รองผู้อำนวยการ', 'กิจการ'), l: 'ฝ่ายกิจการนักเรียน นักศึกษา' },
                { p: findEx('รองผู้อำนวยการ', 'วิชาการ'), l: 'ฝ่ายวิชาการ' }
                ].filter(x => x.p);

                const uniqueDeputies = [];
                const seenIds = new Set();
                dList.forEach(item => {
                if(!seenIds.has(item.p.id)) {
                seenIds.add(item.p.id);
                uniqueDeputies.push(item.p);
                }
                });
                %>
                <div class="mgmt-section">
                  <h3 class="mgmt-h3">ปัจจุบันบริหารงานโดย</h3>
                  <div class="mgmt-grid">
                    <% if(dir) { %>
                      <div class="mgmt-card">
                        <img src="<%= dir.imageUrl || '/images/default-person.svg' %>" class="mgmt-img"
                          alt="ผู้อำนวยการ">
                        <div class="mgmt-info">
                          <div class="mgmt-name">
                            <%= (dir.prefix||'') + dir.firstName + ' ' + dir.lastName %>
                          </div>
                          <div class="mgmt-pos">ผู้อำนวยการวิทยาลัยการอาชีพบ่อไร่</div>
                          <div class="mgmt-contact">
                            <% if(dir.phone) { %>
                              <a href="tel:<%= dir.phone %>" class="contact-item">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                  stroke-linejoin="round">
                                  <path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                </svg>
                                <%= dir.phone %>
                              </a>
                              <% } %>
                                <% if(dir.email) { %>
                                  <a href="mailto:<%= dir.email %>" class="contact-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                      fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                      stroke-linejoin="round">
                                      <path
                                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                      <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                    <%= dir.email %>
                                  </a>
                                  <% } %>
                          </div>
                        </div>
                      </div>
                      <% } %>

                        <div class="mgmt-deputies-grid">
                          <% uniqueDeputies.forEach(p=> { %>
                            <div class="mgmt-card is-deputy">
                              <img src="<%= p.imageUrl || '/images/default-person.svg' %>" class="mgmt-img"
                                alt="รองผู้อำนวยการ">
                              <div class="mgmt-info">
                                <div class="mgmt-name">
                                  <%= (p.prefix||'') + p.firstName + ' ' + p.lastName %>
                                </div>
                                <div class="mgmt-pos">รองผู้อำนวยการ</div>
                                <div class="mgmt-contact">
                                  <% if(p.phone) { %>
                                    <a href="tel:<%= p.phone %>" class="contact-item">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path
                                          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                      </svg>
                                      <%= p.phone %>
                                    </a>
                                    <% } %>
                                      <% if(p.email) { %>
                                        <a href="mailto:<%= p.email %>" class="contact-item">
                                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path
                                              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                            <polyline points="22,6 12,13 2,6" />
                                          </svg>
                                          <%= p.email %>
                                        </a>
                                        <% } %>
                                </div>
                              </div>
                            </div>
                            <% }) %>
                        </div>
                  </div>
                </div>
            </div>
            <div class="identity-container">
              <div class="split-visual-box">
                <img src="/images/college-hero.webp" alt="College Campus"
                  onerror="this.src='/images/college-about.png'">
              </div>

              <!-- College Identity Section -->
              <div class="identity-box">
                <div class="id-header">สัญลักษณ์และสีประจำวิทยาลัย</div>

                <div class="id-logo-wrap">
                  <img src="/my-logo.webp" class="id-logo" alt="Logo">
                </div>

                <div class="id-row">
                  <div class="id-lbl">สีประจำวิทยาลัย</div>
                  <div class="id-val" style="display: flex; align-items: center; gap: 4px;">
                    <img src="/images/ruby-bg.png" class="id-ruby-thumb" alt="Ruby">
                    <div>
                      <div class="id-color-swatch" style="margin-bottom: 4px;margin-left: 14px;">
                        <div class="swatch sw-purple" style="background: #921010;"></div>

                      </div>
                      <p style="margin-left: 14px;">แดงทับทิม</p>
                    </div>

                  </div>
                </div>

                <div class="id-row">
                  <div class="id-lbl">เอกลักษณ์</div>
                  <div class="id-val">"ผู้เรียนมีจิตใจมุ่งคุณธรรม"</div>
                </div>

                <div class="id-row">
                  <div class="id-lbl">อัตลักษณ์</div>
                  <div class="id-val">"สถานศึกษาส่งเสริมคุณธรรม"</div>
                </div>

                <div class="id-row" style="border-bottom:none;">
                  <div class="id-lbl">อักษรย่อ</div>
                  <div class="id-val">วก.บ่อไร่ (BICEC)</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 2. ข้อมูลนักเรียน -->
        <section id="student-info" class="info-section reveal">
          <div class="section-label">
            <span class="section-eyebrow">Student Demographics</span>
            <span class="section-accent-dot" style="background: var(--a-blue);"></span>
          </div>
          <h2 class="section-h2">ข้อมูลนักเรียน นักศึกษา</h2>
          <div class="section-body">
            <p>สถิติจำนวนผู้เรียนจำแนกตามสาขาวิชาและระดับชั้น ประจำปีการศึกษาปัจจุบัน เพื่อประกอบการวางแผนจัดการศึกษา
            </p>
          </div>

          <% 
            const sem = locals.currentSemester || '1';
            const year = locals.academicYear || '2567';
            // Get combined data: DB Enrollments + Department Names
            let studentData = [];
            let totalInterns = 0;
            let pvcInterns = 0;
            let pvsInterns = 0;

            if (locals.enrollments && locals.enrollments.length > 0) {
              studentData = enrollments.map(en => {
                const deptInfo = departments[en.departmentSlug] || {};

                // Calculate interns for this specific department
                let dPvcInt = 0;
                let dPvsInt = 0;

                if (sem === '1') {
                  dPvcInt = en.pvc3;
                  dPvsInt = en.pvs2;
                } else {
                  dPvsInt = en.pvs1;
                }

                const deptInterns = dPvcInt + dPvsInt;
                totalInterns += deptInterns;
                pvcInterns += dPvcInt;
                pvsInterns += dPvsInt;

                return {
                  name: deptInfo.name || en.departmentSlug,
                  v1: en.pvc1, v2: en.pvc2, v3: en.pvc3, s1: en.pvs1, s2: en.pvs2,
                  interns: deptInterns
                };
              });
            }

            const totals = { v1: 0, v2: 0, v3: 0, s1: 0, s2: 0, all: 0 };
            studentData.forEach(d => {
              totals.v1 += d.v1;
              totals.v2 += d.v2;
              totals.v3 += d.v3;
              totals.s1 += d.s1;
              totals.s2 += d.s2;
              totals.all += (d.v1 + d.v2 + d.v3 + d.s1 + d.s2);
            });
          %>



            <div class="data-wrap">
              <table class="data-table" style="min-width: 800px;">
                <thead>
                  <tr>
                    <th rowspan="2" style="vertical-align: middle; border-right: 1px solid rgba(255,255,255,0.1);">
                      สาขาวิชา</th>
                    <th colspan="3"
                      style="text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.1);">
                      ระดับ ปวช.</th>
                    <th colspan="2"
                      style="text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.1);">
                      ระดับ ปวส.</th>
                    <th rowspan="2" style="vertical-align: middle; text-align: center;">รวม</th>
                  </tr>
                  <tr>
                    <th style="text-align: center;">ปี 1</th>
                    <th style="text-align: center;">ปี 2</th>
                    <th style="text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">ปี 3</th>
                    <th style="text-align: center;">ปี 1</th>
                    <th style="text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">ปี 2</th>
                  </tr>
                </thead>
                <tbody>
                  <% studentData.forEach(dept=> { %>
                    <% const rowSum=dept.v1 + dept.v2 + dept.v3 + dept.s1 + dept.s2; %>
                      <tr>
                        <td style="font-weight: 700; color: var(--a-text);">
                          <%= dept.name %>
                        </td>
                        <td style="text-align: center;">
                          <%= dept.v1 %>
                        </td>
                        <td style="text-align: center;">
                          <%= dept.v2 %>
                        </td>
                        <td style="text-align: center; border-right: 1px solid #f1f5f9;"
                          class="<%= sem === '1' ? 'intern-highlight' : '' %>">
                          <%= dept.v3 %>
                        </td>
                        <td style="text-align: center;" class="<%= sem === '2' ? 'intern-highlight' : '' %>">
                          <%= dept.s1 %>
                        </td>
                        <td style="text-align: center; border-right: 1px solid #f1f5f9;"
                          class="<%= sem === '1' ? 'intern-highlight' : '' %>">
                          <%= dept.s2 %>
                        </td>
                        <td style="text-align: center; font-weight: 800; color: var(--a-purple); background: #fdfcff;">
                          <%= rowSum %>
                        </td>
                      </tr>
                      <% }) %>
                </tbody>
                <tfoot style="background: #f8fafc; font-weight: 800; border-top: 2px solid var(--a-border);">
                  <tr>
                    <td style="color: var(--a-text);">ยอดรวมทั้งสิ้น</td>
                    <td style="text-align: center; color: var(--a-blue);">
                      <%= totals.v1 %>
                    </td>
                    <td style="text-align: center; color: var(--a-blue);">
                      <%= totals.v2 %>
                    </td>
                    <td style="text-align: center; color: var(--a-blue); border-right: 1px solid #e2e8f0;">
                      <%= totals.v3 %>
                    </td>
                    <td style="text-align: center; color: var(--a-purple);">
                      <%= totals.s1 %>
                    </td>
                    <td style="text-align: center; color: var(--a-purple); border-right: 1px solid #e2e8f0;">
                      <%= totals.s2 %>
                    </td>
                    <td style="text-align: center; font-size: 1.1rem; background: var(--a-purple); color: #fff;">
                      <%= totals.all %>
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <!-- Internship Status Card (Moved from above table) -->
            <div class="vm-grid" style="margin-top: 24px;">
              <div class="vm-card"
                style="border-left-color: #10b981; background: linear-gradient(to right, #ffffff, #f0fdf4);">
                <div class="vm-label" style="color: #059669; display: flex; align-items: center; gap: 6px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                  </svg>
                  สถานะการฝึกงาน (ภาคเรียนที่ <%= sem %>/<%= year %>)
                </div>
                <div style="display: flex; align-items: center; gap: 20px; margin-top: 5px;">
                  <div>
                    <div style="display: flex; align-items: baseline; gap: 4px;">
                      <span style="font-size: 2.2rem; font-weight: 900; color: #065f46;">
                        <%= totalInterns %>
                      </span>
                      <span style="font-size: 0.95rem; font-weight: 700; color: #059669;">คน</span>
                    </div>
                    <div style="font-size: 0.72rem; color: #065f46; font-weight: 600; opacity: 0.8; margin-top: -5px;">
                      ยอดรวมทั้งหมด</div>
                  </div>

                  <div style="width: 1px; height: 40px; background: rgba(5, 150, 105, 0.1);"></div>

                  <div style="display: flex; flex-direction: column; gap: 2px;">
                    <div style="font-size: 0.85rem; font-weight: 700; color: #065f46;">
                      ปวช: <span style="color: #10b981; font-weight: 900;">
                        <%= pvcInterns %>
                      </span> <small>คน</small>
                    </div>
                    <div style="font-size: 0.85rem; font-weight: 700; color: #065f46;">
                      ปวส: <span style="color: #10b981; font-weight: 900;">
                        <%= pvsInterns %>
                      </span> <small>คน</small>
                    </div>
                  </div>
                </div>
              </div>
              <div class="vm-card"
                style="border-left-color: #f59e0b; background: linear-gradient(to right, #ffffff, #fffbeb);">
                <div class="vm-label" style="color: #b45309; display: flex; align-items: center; gap: 6px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                  ระบบทวิภาคี (Dual Vocational)
                </div>
                <div style="font-size: 0.9rem; font-weight: 700; color: #92400e; margin-top: 8px; line-height: 1.5;">
                  เรียนรู้ควบคู่การปฏิบัติงานจริง<br>ในสถานประกอบการชั้นนำ
                </div>
              </div>
            </div>
        </section>

        <!-- 3. ข้อมูลบุคลากร -->
        <section id="staff-info" class="info-section reveal">
          <div class="section-label">
            <span class="section-eyebrow">Human Resources</span>
            <span class="section-accent-dot" style="background: #f59e0b;"></span>
          </div>
          <h2 class="section-h2">ข้อมูลบุคลากร</h2>
          <div class="section-body">
            <p>วิทยาลัยขับเคลื่อนโดยทีมงานมืออาชีพ
              ทั้งคณะครูผู้เชี่ยวชาญในสายวิชาชีพและบุคลากรสายสนับสนุนที่มีประสิทธิภาพ</p>
          </div>
          <% let summary={}; if (typeof allPersonnel !=='undefined' && allPersonnel.length> 0) {
            allPersonnel.forEach(p => {
            let pos = (p.position && p.position.trim() !== '-' && p.position.trim() !== '') ? p.position.trim() :
            'อื่นๆ';
            summary[pos] = (summary[pos] || 0) + 1;
            });
            }
            const summaryArray = Object.entries(summary).sort((a,b) => b[1] - a[1]);
            %>
            <% if (summaryArray.length> 0) { %>
              <div class="summary-card">
                <table class="summary-table">
                  <thead>
                    <tr>
                      <th>ตำแหน่ง / สายงาน</th>
                      <th style="text-align: center; width: 120px;">จำนวน (คน)</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% summaryArray.forEach(([pos, count])=> { %>
                      <tr>
                        <td>
                          <div class="sum-pos-label">
                            <span class="sum-dot"></span>
                            <%= pos %>
                          </div>
                        </td>
                        <td style="text-align: center; font-weight: 700; color: var(--a-purple); font-size: 1.05rem;">
                          <%= count %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                  <tfoot>
                    <tr>
                      <td style="font-weight: 800; color: #0f172a;">รวมบุคลากรทั้งสิ้น</td>
                      <td style="text-align: center; font-weight: 900; font-size: 1.15rem; color: #10b981;">
                        <%= allPersonnel.length %>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
              <div style="margin-top:20px;">
                <a href="/personnel"
                  style="display:inline-flex;align-items:center;gap:8px;font-size:0.9rem;font-weight:700;color:var(--a-purple);text-decoration:none;">
                  ดูทำเนียบบุคลากรทั้งหมด
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
              <% } else { %>
                <div class="asset-grid">
                  <div class="asset-chip">
                    <div class="chip-dot"></div>กำลังปรับปรุงข้อมูล...
                  </div>
                </div>
                <% } %>
        </section>

        <!-- 4. ข้อมูลหลักสูตร -->
        <section id="departments" class="info-section reveal">
          <div class="section-label">
            <span class="section-eyebrow">Academic Programs</span>
            <span class="section-accent-dot" style="background: #10b981;"></span>
          </div>
          <h2 class="section-h2">ข้อมูลหลักสูตรที่เปิดสอน</h2>
          <div class="section-body">
            <p>นอกจากนี้ยังมีหลักสูตรระยะสั้นเพื่อกลุ่มวิชาชีพเฉพาะกิจ
              และหลักสูตรทวิภาคีที่ร่วมมือกับสถานประกอบการชั้นนำ</p>
          </div>
          <div class="dept-grid"
            style="margin-top:2.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
            <% 
              const displayOrder = ['automotive', 'electrical', 'electronics', 'accounting', 'digital-business'];
              const colors = {
                'automotive': '#ef4444',
                'electrical': '#10b981',
                'electronics': '#06b6d4',
                'accounting': '#f59e0b',
                'digital-business': '#8b5cf6'
              };
              displayOrder.forEach((slug, index) => {
                const d = departments[slug];
                if (!d) return;
                const iconColor = colors[slug] || '#7042f8';
            %>
              <div class="dept-card glass reveal-scale" 
                   style="transition-delay:<%= index * 0.1 %>s; border-radius: 20px; padding: 24px; text-align: center; border: 1px solid var(--a-border); background: #fff; box-shadow: 0 4px 16px rgba(112, 66, 248, 0.05); position: relative; transition: all 0.3s ease;">
                
                <div class="dept-icon" style="background: linear-gradient(135deg, <%= iconColor %>40, <%= iconColor %>); width: 60px; height: 60px; border-radius: 16px; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; color: white;">
                  <% if (d.icon === 'truck') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  <% } else if (d.icon === 'zap') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  <% } else if (d.icon === 'cpu') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
                  <% } else if (d.icon === 'book') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                  <% } else if (d.icon === 'briefcase') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                  <% } %>
                </div>
                
                <h3 class="dept-name" style="font-size: 1.15rem; font-weight: 800; color: var(--a-text); margin-bottom: 20px;"><%= d.name %></h3>
                
                <div style="display: flex; gap: 10px; justify-content: center;">
                  <a href="/curriculum/<%= d.slug %>#pvc" 
                     class="glass-badge" 
                     style="flex: 1; padding: 10px 6px; background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(112, 66, 248, 0.15); border-radius: 12px; color: var(--a-purple); font-size: 0.85rem; font-weight: 800; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(112, 66, 248, 0.04); display: flex; flex-direction: column; align-items: center; gap: 2px;">
                    ปวช.
                    <span style="font-size: 0.65rem; font-weight: 600; opacity: 0.8;">(ปกติ)</span>
                  </a>
                  <a href="/curriculum/<%= d.slug %>#hvc" 
                     class="glass-badge" 
                     style="flex: 1; padding: 10px 6px; background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(112, 66, 248, 0.15); border-radius: 12px; color: var(--a-purple); font-size: 0.85rem; font-weight: 800; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(112, 66, 248, 0.04); display: flex; flex-direction: column; align-items: center; gap: 2px;">
                    ปวส.
                    <span style="font-size: 0.65rem; font-weight: 600; opacity: 0.8;">(ทวิภาคี)</span>
                  </a>
                </div>

                <!-- Card overlay link for the general area -->
                <a href="/curriculum/<%= d.slug %>" style="position: absolute; top:0; left:0; width:100%; height:60%; z-index:1;"></a>
              </div>
            <% }) %>
          </div>
          <div style="margin-top:20px;">
            <a href="/curriculum"
              style="display:inline-flex;align-items:center;gap:8px;font-size:0.9rem;font-weight:700;color:var(--a-purple);text-decoration:none;">
              ดูรายละเอียดหลักสูตรทั้งหมด
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </section>


        <!-- 5. งบประมาณ -->
        <section id="budget-info" class="info-section reveal">
          <div class="section-label">
            <span class="section-eyebrow">Finance &amp; Budget</span>
            <span class="section-accent-dot" style="background: #f43f5e;"></span>
          </div>
          <h2 class="section-h2">การบริหารจัดการงบประมาณ</h2>
          <div class="section-body">
            <p>การดำเนินงานทางการเงินเป็นไปอย่างโปร่งใส ตรวจสอบได้
              โดยมีการจัดสรรงบประมาณที่มุ่งเน้นประโยชน์ของผู้เรียนเป็นสำคัญ</p>
          </div>

          <div class="budget-container" style="position: relative; margin-top: 2rem;">
            <% if (budgetInfoStatus === 'maintenance') { %>
              <!-- Maintenance Mode View -->
              <div style="background: #fff; padding: 60px 40px; border-radius: 24px; box-shadow: 0 15px 45px rgba(0,0,0,0.05); text-align: center; border: 1px solid var(--a-border); margin: 2rem 0;">
                <div style="background: rgba(245, 158, 11, 0.1); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                  </svg>
                </div>
