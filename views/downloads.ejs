<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ศูนย์ดาวน์โหลดเอกสาร แบบฟอร์มต่างๆ แบ่งตามฝ่ายงาน - วิทยาลัยการอาชีพบ่อไร่" />
  <title><%= title %></title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .dl-page {
      padding: 140px 0 100px;
      min-height: 80vh;
      background: linear-gradient(180deg, rgba(250, 250, 252, 0.5) 0%, rgba(243, 244, 246, 0.7) 100%);
    }

    .dl-header {
      margin-bottom: 3.5rem;
      text-align: center;
    }

    .dl-title {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, var(--color-accent-primary) 0%, var(--color-accent-secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    
    .dl-subtitle {
      font-size: 1.15rem;
      color: var(--color-text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .dl-page { padding-top: 110px; }
      .dl-title { font-size: 2.4rem; }
    }

    /* Live Search Styling */
    .dl-search-container {
      max-width: 700px;
      margin: 0 auto 3.5rem;
      position: relative;
      z-index: 10;
    }

    .dl-search-input {
      width: 100%;
      padding: 1.25rem 1.5rem 1.25rem 3.5rem;
      font-size: 1.15rem;
      font-family: inherit;
      color: var(--color-text-primary);
      background: rgba(255, 255, 255, 0.85);
      border: 2px solid rgba(112, 66, 248, 0.15);
      border-radius: 100px;
      box-shadow: 0 10px 30px rgba(112, 66, 248, 0.08);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      outline: none;
    }

    .dl-search-input:focus {
      border-color: var(--color-accent-primary);
      box-shadow: 0 15px 40px rgba(112, 66, 248, 0.15);
      background: rgba(255, 255, 255, 0.98);
    }

    .dl-search-icon {
      position: absolute;
      left: 1.4rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-accent-primary);
      opacity: 0.7;
    }

    .dl-search-input::placeholder {
      color: #94a3b8;
    }

    /* Accordion / Category UI */
    .dl-content-wrap {
      max-width: 900px;
      margin: 0 auto;
    }

    .division-group {
      margin-bottom: 2rem;
      background: rgba(255, 255, 255, 0.7);
      border: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
      transition: box-shadow 0.3s ease;
    }

    .division-group:hover {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
    }

    .division-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 1.75rem;
      cursor: pointer;
      background: linear-gradient(90deg, rgba(255,255,255,0.8) 0%, rgba(248,250,252,0.8) 100%);
      user-select: none;
      transition: background 0.3s ease;
    }

    .division-header:hover {
      background: rgba(248, 250, 252, 1);
    }

    .division-title {
      font-size: 1.35rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--color-text-primary);
    }

    .division-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: rgba(112, 66, 248, 0.1);
      color: var(--color-accent-primary);
      border-radius: 10px;
    }

    .division-arrow {
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      color: #94a3b8;
    }

    .division-group.active .division-arrow {
      transform: rotate(180deg);
    }

    .division-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .division-body-inner {
      padding: 0 1.75rem 1.75rem;
    }

    /* Sub-Divisions and Items */
    .subdivision-group {
      margin-top: 1.5rem;
    }

    .subdivision-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #475569;
      margin-bottom: 0.8rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px dashed #e2e8f0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .subdivision-title::before {
      content: '';
      width: 6px;
      height: 14px;
      background: var(--color-accent-secondary);
      border-radius: 4px;
    }

    .doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
    }

    .doc-card {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      background: white;
      border: 1px solid #f1f5f9;
      border-radius: 12px;
      text-decoration: none;
      transition: all 0.25s ease;
      box-shadow: 0 2px 8px rgba(0,0,0,0.01);
    }

    .doc-card:hover {
      border-color: rgba(112, 66, 248, 0.3);
      box-shadow: 0 8px 16px rgba(112, 66, 248, 0.08);
      transform: translateY(-4px);
    }

    .doc-file-icon {
      width: 44px;
      height: 44px;
      flex-shrink: 0;
      background: #f8fafc;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .doc-info {
      flex-grow: 1;
      width: 0;
    }

    .doc-name {
      font-weight: 600;
      color: var(--color-text-primary);
      margin-bottom: 0.2rem;
      font-size: 0.95rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color 0.2s;
    }

    .doc-card:hover .doc-name {
      color: var(--color-accent-primary);
    }

    .doc-meta {
      font-size: 0.75rem;
      color: #94a3b8;
    }

    /* Empty States & Search Responses */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: #64748b;
    }
    
    .hidden {
      display: none !important;
    }
  </style>
</head>

<body>
  <!-- Floating orb canvas -->
  <div class="section-canvas-wrap">
    <canvas id="section-canvas"></canvas>
  </div>

  <%- include('partials/navbar'); %>

  <main class="dl-page">
    <div class="container relative z-10">
      
      <div class="dl-header reveal">
        <h1 class="dl-title">ศูนย์ดาวน์โหลดเอกสาร</h1>
        <p class="dl-subtitle">รวมแบบฟอร์มและเอกสารสำคัญต่างๆ จัดเรียงตามฝ่ายงานและงานย่อย เพื่อความสะดวกในการค้นหาและดาวน์โหลด</p>
      </div>

      <div class="dl-search-container reveal" style="transition-delay: 100ms;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="dl-search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="dl-search" class="dl-search-input" placeholder="ค้นหาชื่อเอกสาร, ฝ่ายงาน หรือ งานย่อย..." autocomplete="off">
      </div>

      <div class="dl-content-wrap" id="dl-container">
        <!-- Rendered via JS -->
      </div>
      
      <div id="no-results" class="empty-state hidden">
        <div style="font-size: 4rem; opacity: 0.5; margin-bottom: 1rem;">🔍</div>
        <h3 style="font-size: 1.5rem; color: var(--color-text-primary); margin-bottom: 0.5rem;">ไม่พบเอกสารที่ค้นหา</h3>
        <p>ลองใช้คำค้นหาอื่น หรือตรวจสอบตัวสะกดอีกครั้ง</p>
      </div>

    </div>
  </main>

  <%- include('partials/footer'); %>

  <!-- Data payload from backend -->
  <script>
    const rawDocs = <%- JSON.stringify(docs || []) %>;
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const dlContainer = document.getElementById('dl-container');
      const searchInput = document.getElementById('dl-search');
      const noResultsBox = document.getElementById('no-results');

      // Helper for file icons based on title/url (Fallback heuristic)
      const getFileIcon = (url, title) => {
        const text = (url + ' ' + title).toLowerCase();
        if (text.includes('.pdf') || text.includes('pdf')) return '📕';
        if (text.includes('.doc') || text.includes('word')) return '📘';
        if (text.includes('.xls') || text.includes('excel')) return '📗';
        if (text.includes('.zip') || text.includes('.rar')) return '📦';
        return '📄';
      };

      // Transform rawDocs to grouped structure
      // Structure: { [division]: { [subDivision]: [ doc1, doc2 ] } }
      function groupDocs(docsList) {
        const grouped = {};
        docsList.forEach(doc => {
          if (!grouped[doc.division]) {
            grouped[doc.division] = {};
          }
          if (!grouped[doc.division][doc.subDivision]) {
            grouped[doc.division][doc.subDivision] = [];
          }
          grouped[doc.division][doc.subDivision].push(doc);
        });
        return grouped;
      }

      function render(docsList, forceExpandAll = false) {
        if (docsList.length === 0) {
          dlContainer.innerHTML = '';
          noResultsBox.classList.remove('hidden');
          return;
        }
        noResultsBox.classList.add('hidden');

        const grouped = groupDocs(docsList);
        const divisions = Object.keys(grouped).sort(); // Sort divisions alphabetically if needed
        let html = '';

        divisions.forEach((divName, i) => {
          const subDivisions = Object.keys(grouped[divName]).sort();
          // By default, expand first item if not searching. If searching, expand all that have results.
          const isExpanded = forceExpandAll || i === 0;
          
          let subDivHtml = '';
          subDivisions.forEach(subName => {
            const items = grouped[divName][subName];
            subDivHtml += `
              <div class="subdivision-group">
                <h4 class="subdivision-title">${subName}</h4>
                <div class="doc-grid">
                  ${items.map(doc => `
                    <a href="${doc.fileUrl}" download="${doc.title}" target="_blank" class="doc-card">
                      <div class="doc-file-icon">${getFileIcon(doc.fileUrl, doc.title)}</div>
                      <div class="doc-info">
                        <div class="doc-name" title="${doc.title}">${doc.title}</div>
                        <div class="doc-meta">อัปเดต: ${new Date(doc.createdAt).toLocaleDateString('th-TH')}</div>
                      </div>
                    </a>
                  `).join('')}
                </div>
              </div>
            `;
          });

          html += `
            <div class="division-group ${isExpanded ? 'active' : ''}">
              <div class="division-header" onclick="toggleAccordion(this)">
                <div class="division-title">
                  <div class="division-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                  </div>
                  ${divName}
                </div>
                <div class="division-arrow">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
              </div>
              <div class="division-body" style="${isExpanded ? 'max-height: 2000px;' : ''}">
                <div class="division-body-inner">
                  ${subDivHtml}
                </div>
              </div>
            </div>
          `;
        });

        dlContainer.innerHTML = html;
        
        // Recalculate max height dynamically for smoother transitions if active
        document.querySelectorAll('.division-group.active .division-body').forEach(body => {
          body.style.maxHeight = body.scrollHeight + "px";
        });
      }

      window.toggleAccordion = function(headerElem) {
        const group = headerElem.parentElement;
        const body = group.querySelector('.division-body');
        
        if (group.classList.contains('active')) {
          group.classList.remove('active');
          body.style.maxHeight = '0';
        } else {
          group.classList.add('active');
          body.style.maxHeight = body.scrollHeight + 100 + "px"; // Adding extra buffer for inner wrap
        }
      };

      // Live Search Filter
      searchInput.addEventListener('input', (e) => {
        const term = e.target.value.trim().toLowerCase();
        if (!term) {
          render(rawDocs, false);
          return;
        }

        const filtered = rawDocs.filter(doc => {
          return doc.title.toLowerCase().includes(term) ||
                 doc.division.toLowerCase().includes(term) ||
                 doc.subDivision.toLowerCase().includes(term);
        });

        render(filtered, true); // force expand all groups when searching
      });

      // Initial Render
      render(rawDocs, false);
    });
  </script>

  <script src="/js/webgl-bg.js"></script>
  <script src="/js/particles.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
