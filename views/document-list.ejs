<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ข่าวประกวดราคาและเอกสารเผยแพร่ทั้งหมด - วิทยาลัยการอาชีพบ่อไร่" />
  <title><%= title %></title>
  <link rel="icon" href="/my-logo.webp" type="image/webp" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .docs-page {
      padding: 120px 0 80px;
      min-height: 80vh;
    }

    .docs-header {
      margin-bottom: 4rem;
      text-align: center;
    }

    .docs-title {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
      .docs-title { font-size: 2.2rem; }
    }

    .btn-tab {
      padding: 0.6rem 1.75rem;
      border-radius: 100px;
      border: 1px solid rgba(226, 232, 240, 0.8);
      background: white;
      color: var(--color-text-primary);
      cursor: pointer;
      font-weight: 600;
      font-size: 0.95rem;
      font-family: inherit;
      transition: all 0.3s ease;
    }

    .btn-tab:hover {
      background: rgba(112, 66, 248, 0.05);
      color: var(--color-accent-primary);
      border-color: var(--color-accent-primary);
    }

    .btn-tab.active {
      background: var(--color-accent-primary);
      color: white;
      border-color: var(--color-accent-primary);
    }

    .tab-pane {
      display: none;
      animation: fadeIn 0.4s ease forwards;
    }

    .tab-pane.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Document List Item Styling */
    .doc-item-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .doc-item-card {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.25rem 1.5rem;
      border-radius: 1.25rem;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .doc-item-card:hover {
      transform: translateX(10px);
      background: rgba(112, 66, 248, 0.05);
    }

    .doc-icon-wrap {
      flex-shrink: 0;
      width: 50px;
      height: 50px;
      background: rgba(112, 66, 248, 0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-accent-primary);
    }

    .doc-info {
      flex-grow: 1;
    }

    .doc-title-text {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: 0.4rem;
      display: block;
    }

    .doc-meta {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      font-size: 0.85rem;
      color: var(--color-text-secondary);
    }

    .doc-type-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.25rem 0.75rem;
      border-radius: 100px;
      font-weight: 700;
      font-size: 0.75rem;
      text-transform: uppercase;
    }

    .badge-bidding { background: rgba(245, 158, 11, 0.1); color: #d97706; border: 1px solid rgba(245, 158, 11, 0.2); }
    .badge-general { background: rgba(139, 92, 246, 0.1); color: #7c3aed; border: 1px solid rgba(139, 92, 246, 0.2); }

    .doc-arrow {
      color: var(--color-accent-primary);
      opacity: 0;
      transition: all 0.3s ease;
    }

    .doc-item-card:hover .doc-arrow {
      opacity: 1;
      transform: translateX(5px);
    }
  </style>
</head>

<body>
  <!-- Floating orb canvas -->
  <div class="section-canvas-wrap">
    <canvas id="section-canvas"></canvas>
  </div>

  <%- include('partials/navbar'); %>

  <main class="docs-page">
    <div class="container">
      <div class="docs-header reveal">
        <h1 class="docs-title"><span class="text-gradient">เอกสาร</span> และข่าวประกวดราคา</h1>
        <p style="color:var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
          รวบรวมประกาศจัดซื้อจัดจ้าง เอกสารเผยแพร่ และข้อมูลสำคัญของวิทยาลัยการอาชีพบ่อไร่
        </p>
      </div>

      <!-- Back Button -->
      <div style="margin-bottom: 3rem; display: flex; justify-content: center;">
        <a href="/#news" class="btn-outline" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; border-radius: 100px; padding: 0.6rem 1.5rem; font-weight: 600;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          กลับสู่หน้าเลือกข่าว
        </a>
      </div>

      <!-- Tabs Header -->
      <div class="docs-tabs" style="display: flex; gap: 0.75rem; margin-bottom: 4rem; flex-wrap: wrap; justify-content: center;">
        <button class="btn-tab <%= activeType === 'all' ? 'active' : '' %>" data-target="tab-all">ทั้งหมด</button>
        <button class="btn-tab <%= activeType === 'bidding' ? 'active' : '' %>" data-target="tab-bidding">ข่าวประกวดราคา</button>
        <button class="btn-tab <%= activeType === 'general' ? 'active' : '' %>" data-target="tab-general">เอกสารเผยแพร่</button>
      </div>

      <!-- Tab Panes -->
      <% 
        const biddingDocs = docs.filter(d => d.type === 'bidding');
        const generalDocs = docs.filter(d => d.type === 'general');
      %>

      <% function renderDocCard(item, index) { 
          const dateParts = (item.date || '').split(' ');
          const day = dateParts[0] || '';
          const month = dateParts[1] || '';
      %>
        <a href="<%= item.fileUrl %>" download="<%= item.title %>.<%= item.fileUrl.split('.').pop() %>" target="_blank" class="doc-item-card glass reveal">
          <div class="sub-item-date-box" style="width: 45px; height: 45px; border-radius: 10px;">
            <span class="date-day" style="font-size: 1.1rem;"><%= day %></span>
            <span class="date-month" style="font-size: 0.6rem;"><%= month %></span>
          </div>
          <div class="doc-info">
            <span class="doc-title-text"><%= item.title %></span>
            <div class="doc-meta">
              <span class="doc-type-badge <%= item.type === 'bidding' ? 'badge-bidding' : 'badge-general' %>">
                <%= item.type === 'bidding' ? 'ประกวดราคา' : 'เอกสารเผยแพร่' %>
              </span>
              <span><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg> PDF Document</span>
            </div>
          </div>
          <div class="doc-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
          </div>
        </a>
      <% } %>

      <!-- All Documents -->
      <div id="tab-all" class="tab-pane <%= activeType === 'all' ? 'active' : '' %>">
        <div class="doc-item-list">
          <% if (docs.length > 0) { docs.forEach(renderDocCard); } else { %>
            <p style="text-align:center; color:var(--color-text-secondary);">ยังไม่มีรายการเอกสารในขณะนี้</p>
          <% } %>
        </div>
      </div>

      <!-- Bidding Only -->
      <div id="tab-bidding" class="tab-pane <%= activeType === 'bidding' ? 'active' : '' %>">
        <div class="doc-item-list">
          <% if (biddingDocs.length > 0) { biddingDocs.forEach(renderDocCard); } else { %>
            <p style="text-align:center; color:var(--color-text-secondary);">ยังไม่มีข่าวประกวดราคาในขณะนี้</p>
          <% } %>
        </div>
      </div>

      <!-- General Docs Only -->
      <div id="tab-general" class="tab-pane <%= activeType === 'general' ? 'active' : '' %>">
        <div class="doc-item-list">
          <% if (generalDocs.length > 0) { generalDocs.forEach(renderDocCard); } else { %>
            <p style="text-align:center; color:var(--color-text-secondary);">ยังไม่มีเอกสารเผยแพร่ในขณะนี้</p>
          <% } %>
        </div>
      </div>

    </div>
  </main>

  <%- include('partials/footer'); %>

  <script src="/js/webgl-bg.js"></script>
  <script src="/js/particles.js"></script>
  <script src="/js/main.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.btn-tab');
      const panes = document.querySelectorAll('.tab-pane');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          panes.forEach(p => p.classList.remove('active'));

          tab.classList.add('active');
          const targetId = tab.getAttribute('data-target');
          document.getElementById(targetId).classList.add('active');
          
          // Smooth scroll to results
          window.scrollTo({ top: document.querySelector('.docs-tabs').offsetTop - 100, behavior: 'smooth' });
        });
      });
    });
  </script>
</body>
</html>
